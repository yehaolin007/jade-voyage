---
import { getCollection } from 'astro:content';

const entries = (await getCollection('services'))
  .sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  entries.map(async (e) => {
    const { Content } = await e.render();
    return { ...e, Content };
  })
);

const serviceQuery = (title: string) => {
  if (title.toLowerCase().includes('check')) return 'Checkup + Travel';
  if (title.toLowerCase().includes('wellness')) return 'TCM Heritage + Travel';
  return 'Custom Travel';
};
---

<section id="services">
  <div class="container">
    <div class="section-head">
      <span class="micro">Our Three Pillars</span>
      <h2>Checkup, TCM heritage and travel in one plan.</h2>
      <p class="deck">Every Harmony Retreats package is built around a practical service flow: efficient health checks, licensed TCM wellness experiences and relaxed Chongqing travel.</p>
      <p class="lead-in">From a thorough health checkup, through licensed TCM heritage care, to slow Chongqing mountain-city travel — three pillars sequenced into one continuous wellness journey.</p>
      <div class="underline"></div>
    </div>

    <div class="services-grid">
      {rendered.map((s) => (
        <div class="service-card">
          <div class="service-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" set:html={s.data.iconSvg} />
          </div>
          <h3>{s.data.title}</h3>
          <div class="service-body"><s.Content /></div>
          <a href={`/contact?service=${encodeURIComponent(serviceQuery(s.data.title))}`} class="arrow-link">{s.data.cta} →</a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .service-body :global(p) {
    color: var(--ink-soft);
    font-size: 15px;
    line-height: 1.6;
    margin-bottom: 24px;
  }
  #services .lead-in {
    max-width: 760px;
    margin: 14px auto 0;
    color: var(--navy);
    font-size: 16px;
    line-height: 1.7;
    font-weight: 500;
    text-align: center;
    border-top: 1px solid rgba(7, 27, 99, 0.08);
    padding-top: 14px;
  }
</style>

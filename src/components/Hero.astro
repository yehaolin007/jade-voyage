---
const destinations = [
  'Chongqing',
];
const services = [
  'Featured Packages',
  'TCM Heritage + Travel',
  'Checkup + Travel',
  'Custom Travel',
];
const months = [
  'Any Month',
  'May 2026', 'Jun 2026', 'Jul 2026', 'Aug 2026', 'Sep 2026',
  'Oct 2026', 'Nov 2026', 'Dec 2026',
];
const proofItems = [
  { value: '2+', label: 'Accredited Medical Partners' },
  { value: '100%', label: 'Privacy Compliance' },
  { value: '24/7', label: 'Customer Support' },
  { value: '4+', label: 'Trusted Local Partners' },
];
---

<header class="hero">
  <div class="container hero-layout">
    <div class="hero-copy">
      <div class="hero-eyebrow">
        <span class="dot"></span>
        Checkup · TCM · Travel
      </div>
      <h1>Welcome to Harmony Retreats</h1>
      <p class="lead">
        Are you ready to begin a journey that blends mind-body healing, cultural exploration and deep relaxation? We specialize in crafting the perfect combination of health checkups, TCM heritage experiences and Chongqing mountain-city travel.
      </p>
      <div class="hero-cta">
        <a href="#tours" class="btn btn-primary">Browse Itineraries</a>
        <a href="/contact" class="btn btn-outline">Speak with a Concierge</a>
      </div>
      <div class="hero-proof" aria-label="Harmony Retreats trust signals">
        {proofItems.map((item) => (
          <div class="proof-item">
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="hero-media" aria-hidden="true">
      <div class="hero-photo hero-photo-wide">
        <img src="/assets/story-concierge-lounge.png" alt="" loading="eager" />
      </div>
      <div class="hero-photo hero-photo-tall">
        <img src="/assets/hangzhou-westlake-retreat.png" alt="" loading="eager" />
      </div>
    </div>
  </div>

  <form class="hero-search" action="/contact" method="GET">
    <label class="hs-field">
      <span class="hs-label">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Destination
      </span>
      <select name="dest">
        {destinations.map((d) => <option value={d}>{d}</option>)}
      </select>
    </label>
    <label class="hs-field">
      <span class="hs-label">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        Package Type
      </span>
      <select name="service">
        {services.map((s) => <option value={s}>{s}</option>)}
      </select>
    </label>
    <label class="hs-field">
      <span class="hs-label">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
        Travel Month
      </span>
      <select name="month">
        {months.map((m) => <option value={m}>{m}</option>)}
      </select>
    </label>
    <button type="submit" class="hs-submit">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      Inquire
    </button>
  </form>
</header>

<style>
  .hero {
    min-height: 680px;
    padding: 54px 0 118px;
    overflow: visible;
    z-index: 2;
    color: var(--ink);
    background:
      radial-gradient(circle at 0 0, rgba(241, 90, 36, 0.12) 0 22px, transparent 24px),
      linear-gradient(90deg, #FFF6F1 0%, #fff 48%, #FFF9F5 100%);
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-radial-gradient(ellipse at 30% 95%, rgba(7, 27, 99, 0.045) 0 1px, transparent 1px 28px);
    opacity: 0.55;
    pointer-events: none;
    z-index: 0;
  }
  .hero::after { display: none; }
  .hero .container { position: relative; z-index: 2; }
  .hero-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.86fr) minmax(500px, 1.14fr);
    gap: clamp(42px, 5vw, 74px);
    align-items: center;
    max-width: 1260px;
  }
  .hero-copy { max-width: 600px; }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--seal);
    font-weight: 800;
    margin-bottom: 18px;
  }
  .hero-eyebrow .dot {
    width: 6px;
    height: 6px;
    background: var(--seal);
    border-radius: 50%;
  }
  .hero h1 {
    font-family: 'Inter', -apple-system, sans-serif;
    font-weight: 900;
    font-size: clamp(44px, 4.2vw, 64px);
    line-height: 1.08;
    letter-spacing: 0;
    max-width: 600px;
    margin-bottom: 20px;
    color: var(--ink);
  }
  .hero .lead {
    font-size: 18px;
    line-height: 1.55;
    max-width: 620px;
    margin-bottom: 28px;
    color: var(--ink-soft);
    font-weight: 400;
  }
  .hero-cta { display: flex; gap: 16px; flex-wrap: wrap; }
  .hero .btn-primary {
    background: var(--seal);
    color: #fff;
    padding: 16px 26px;
    font-weight: 800;
  }
  .hero .btn-primary:hover { background: var(--jade-deep); color: #fff; }
  .hero .btn-outline {
    color: var(--ink);
    border-color: var(--hairline);
    background: #fff;
    padding: 16px 26px;
    font-weight: 800;
  }
  .hero .btn-outline:hover {
    background: var(--ink);
    border-color: var(--ink);
    color: #fff;
  }
  .hero-media {
    min-height: 540px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    align-items: start;
    padding-top: 0;
  }
  .hero-photo {
    overflow: hidden;
    border-radius: 12px;
    background: var(--mist);
    box-shadow: 0 22px 52px rgba(7, 27, 99, 0.12);
    will-change: transform;
  }
  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: translate3d(var(--mx, 0), var(--my, 0), 0) scale(1.03);
    filter: saturate(1.05) brightness(1.02);
    transition: transform 1.1s cubic-bezier(.2,.7,.2,1), filter 0.5s;
  }
  .hero-photo:hover img {
    transform: translate3d(var(--mx, 0), var(--my, 0), 0) scale(1.08);
    filter: saturate(1.12) brightness(1.04);
  }
  .hero-photo-wide {
    height: 475px;
    margin-top: 42px;
    animation: heroFloatA 4.6s ease-in-out infinite;
  }
  .hero-photo-tall {
    height: 540px;
    align-self: start;
    animation: heroFloatB 4.9s ease-in-out infinite;
  }
  @keyframes heroFloatA {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-14px); }
  }
  @keyframes heroFloatB {
    0%, 100% { transform: translateY(-10px); }
    50% { transform: translateY(12px); }
  }

  .hero-proof {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-top: 28px;
    max-width: 560px;
  }
  .proof-item {
    min-height: 78px;
    padding: 14px 16px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid var(--hairline);
    border-radius: 10px;
    box-shadow: 0 12px 30px rgba(7, 27, 99, 0.055);
    backdrop-filter: blur(12px);
    transition: transform 0.24s ease, border-color 0.24s ease, box-shadow 0.24s ease;
  }
  .proof-item:hover {
    transform: translateY(-3px);
    border-color: rgba(241, 90, 36, 0.22);
    box-shadow: 0 16px 36px rgba(7, 27, 99, 0.09);
  }
  .proof-item strong {
    display: block;
    color: var(--seal);
    font-size: 22px;
    font-weight: 900;
    line-height: 1;
    margin-bottom: 8px;
  }
  .proof-item span {
    display: block;
    color: var(--ink-soft);
    font-size: 12px;
    font-weight: 800;
    line-height: 1.35;
  }

  :global(html[data-lang='CN']) .hero-copy { max-width: 650px; }
  :global(html[data-lang='CN']) .hero h1 {
    max-width: 560px;
    font-size: clamp(42px, 4vw, 60px);
    line-height: 1.14;
  }
  :global(html[data-lang='CN']) .hero .lead { font-size: 18px; line-height: 1.65; }

  .hero-search {
    position: absolute;
    left: 50vw;
    bottom: -28px;
    width: min(1120px, calc(100vw - 64px));
    max-width: 1120px;
    transform: translateX(-50%);
    z-index: 3;
    margin-top: 0;
    background: #fff;
    border: 1px solid var(--hairline);
    border-radius: 10px;
    padding: 14px;
    display: grid;
    grid-template-columns: 1.2fr 1.2fr 1fr auto;
    gap: 0;
    box-shadow: 0 18px 46px rgba(7, 27, 99, 0.12);
    align-items: stretch;
    justify-self: center;
  }
  .hs-field {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 60px;
    padding: 8px 22px;
    border-right: 1px solid var(--hairline);
    cursor: pointer;
  }
  .hs-field:nth-child(3) { border-right: none; }
  .hs-label {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--seal);
    font-weight: 800;
    margin-bottom: 5px;
  }
  .hs-field select {
    border: none;
    background: transparent;
    font-family: inherit;
    font-size: 16px;
    font-weight: 700;
    color: var(--ink);
    padding: 4px 0;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6' fill='none' stroke='%23071B63' stroke-width='1.5'><path d='M1 1l4 4 4-4'/></svg>");
    background-repeat: no-repeat;
    background-position: right center;
    padding-right: 18px;
  }
  .hs-field select:focus { outline: none; }
  .hs-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    min-height: 64px;
    background: var(--seal);
    color: #fff;
    border-radius: 8px;
    padding: 0 30px;
    font-size: 16px;
    font-weight: 900;
    cursor: pointer;
    box-shadow: none;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }
  .hs-submit:hover {
    background: var(--jade-deep);
    transform: translateY(-1px);
    box-shadow: 0 14px 28px rgba(241, 90, 36, 0.2);
  }

  @media (max-width: 1000px) {
    .hero-layout { grid-template-columns: 1fr; align-items: start; }
    .hero-media { min-height: 360px; }
    .hero-photo-wide { height: 320px; margin-top: 0; }
    .hero-photo-tall { height: 360px; }
  }

  @media (max-width: 900px) {
    .hero { padding: 54px 0 64px; min-height: auto; }
    .hero h1 { font-size: clamp(38px, 11vw, 52px); }
    .hero-media { grid-template-columns: 1fr; }
    .hero-photo-tall { display: none; }
    .hero-photo-wide { animation: none; }
    .hero-search {
      position: relative;
      left: auto;
      bottom: auto;
      width: auto;
      max-width: none;
      transform: none;
      grid-template-columns: 1fr;
      gap: 4px;
      padding: 12px;
      margin-top: 36px;
    }
    .hero-proof { grid-template-columns: 1fr; }
    .hs-field { border-right: none; border-bottom: 1px solid var(--hairline); padding: 10px 14px; }
    .hs-field:nth-child(3) { border-bottom: none; }
    .hs-submit { padding: 14px; margin-top: 6px; }
  }

  @media (max-width: 640px) {
    .hero-eyebrow {
      align-items: flex-start;
      flex-direction: column;
      gap: 8px;
      letter-spacing: 0.1em;
    }
    .hero-eyebrow .dot { display: none; }
    .hero-cta { flex-direction: column; }
    .hero-cta .btn { justify-content: center; width: 100%; }
  }
</style>

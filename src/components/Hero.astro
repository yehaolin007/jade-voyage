---
const destinations = [
  'Any Destination',
  'Hangzhou · West Lake',
  'Shanghai',
  'Sanya · Hainan',
  'Huangshan · Anhui',
  'Emei · Sichuan',
  'Suzhou · Jiangsu',
  'Yunnan · Tea Forest',
];
const services = [
  'MRI Precision Screening',
  'Wellness Retreat',
  'Cultural Itinerary',
  'Fully Bespoke Journey',
];
const months = [
  'Any Month',
  'May 2026', 'Jun 2026', 'Jul 2026', 'Aug 2026', 'Sep 2026',
  'Oct 2026', 'Nov 2026', 'Dec 2026',
];
---

<header class="hero">
  <div class="hero-seal-mark">
    <span class="seal seal-lg">玉</span>
  </div>
  <div class="container">
    <div class="hero-eyebrow">
      <span class="dot"></span>
      Medical · Wellness · Culture
      <span class="dot"></span>
      Serving Guests From 32 Countries
    </div>
    <h1>Healing Journeys<br />Across <em>Ancient China</em>.</h1>
    <p class="lead">
      Premium health check-ups, traditional wellness retreats and bespoke cultural itineraries — designed for discerning international travelers seeking restoration of body and spirit.
    </p>
    <div class="hero-cta">
      <a href="#tours" class="btn btn-primary">Browse Itineraries</a>
      <a href="/contact" class="btn btn-outline">Speak with a Concierge</a>
    </div>
  </div>

  <form class="hero-search container" action="/contact" method="GET">
    <label class="hs-field">
      <span class="hs-label">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Destination
      </span>
      <select name="dest">
        {destinations.map((d) => <option value={d}>{d}</option>)}
      </select>
    </label>
    <label class="hs-field">
      <span class="hs-label">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        Service Type
      </span>
      <select name="service">
        {services.map((s) => <option value={s}>{s}</option>)}
      </select>
    </label>
    <label class="hs-field">
      <span class="hs-label">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
        Travel Month
      </span>
      <select name="month">
        {months.map((m) => <option value={m}>{m}</option>)}
      </select>
    </label>
    <button type="submit" class="hs-submit">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      Inquire
    </button>
  </form>

  <div class="hero-bottom">
    <div class="container hero-bottom-row">
      <span>JCI · ISO 9001 · Accredited Partners</span>
      <span class="scroll-cue"><span class="line"></span>SCROLL</span>
    </div>
  </div>
</header>

<style>
  .hero::before {
    background-image: url('/assets/jade-hero-wellness.png');
  }
  .hero {
    padding-bottom: 150px;
    overflow: visible;
    z-index: 2;
  }
  .hero-bottom { bottom: 72px; opacity: 0.72; }

  .hero-search {
    position: absolute;
    left: 50%;
    bottom: -44px;
    width: calc(100% - 112px);
    max-width: 1000px;
    transform: translateX(-50%);
    z-index: 3;
    margin-top: 0;
    background: linear-gradient(180deg, rgba(255, 255, 252, 0.95) 0%, rgba(247, 244, 236, 0.92) 100%);
    border: 1px solid rgba(232, 199, 122, 0.24);
    border-radius: 999px;
    padding: 10px 12px;
    display: grid;
    grid-template-columns: 1.2fr 1.2fr 1fr auto;
    gap: 0;
    box-shadow: 0 16px 42px rgba(8, 24, 21, 0.22), inset 0 1px 0 rgba(255, 255, 255, 0.72);
    align-items: stretch;
    backdrop-filter: blur(18px);
  }
  .hs-field {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 54px;
    padding: 7px 18px;
    border-right: 1px solid rgba(31, 58, 54, 0.12);
    cursor: pointer;
  }
  .hs-field:nth-child(3) { border-right: none; }
  .hs-label {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(31, 58, 54, 0.82);
    font-weight: 600;
    margin-bottom: 4px;
  }
  .hs-field select {
    border: none;
    background: transparent;
    font-family: inherit;
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    padding: 4px 0;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6' fill='none' stroke='%231F3A36' stroke-width='1.5'><path d='M1 1l4 4 4-4'/></svg>");
    background-repeat: no-repeat;
    background-position: right center;
    padding-right: 18px;
  }
  .hs-field select:focus { outline: none; }
  .hs-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 56px;
    background: var(--jade-deep);
    color: #fff;
    border: 1px solid rgba(232, 199, 122, 0.2);
    border-radius: 999px;
    padding: 0 26px;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.02em;
    cursor: pointer;
    box-shadow: 0 10px 24px rgba(31, 58, 54, 0.18);
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }
  .hs-submit:hover {
    background: #15302C;
    transform: translateY(-1px);
    box-shadow: 0 14px 28px rgba(31, 58, 54, 0.24);
  }

  @media (max-width: 900px) {
    .hero { padding-bottom: 64px; }
    .hero-bottom { display: none; }
    .hero-search {
      position: relative;
      left: auto;
      bottom: auto;
      width: auto;
      max-width: none;
      transform: none;
      grid-template-columns: 1fr;
      gap: 4px;
      border-radius: 18px;
      padding: 12px;
      margin-top: 36px;
    }
    .hs-field { border-right: none; border-bottom: 1px solid var(--hairline); padding: 10px 14px; }
    .hs-field:nth-child(3) { border-bottom: none; }
    .hs-submit { padding: 14px; margin-top: 6px; }
  }
</style>

---
const steps = [
  {
    dot: '01',
    h: 'Online Reservation',
    p: 'Consult on the official website, order your package, and let a dedicated advisor assist with your China visa preparation.',
  },
  {
    dot: '02',
    h: 'On-site Experience',
    p: 'Multilingual airport pickup and check-in support, with full accompaniment for checkups, TCM wellness and cultural experiences.',
  },
  {
    dot: '03',
    h: 'After-sales Support',
    p: 'Assisted return, one-on-one medical report interpretation, online archive access and ongoing wellness consultation.',
  },
];
---

<section class="process" id="process">
  <div class="container">
    <div class="section-head" style="text-align: center; margin-left: auto; margin-right: auto;">
      <span class="micro">Service Process</span>
      <h2>Three clear steps from booking to follow-up.</h2>
    </div>

    <div class="process-timeline process-three">
      {steps.map((s) => (
        <div class="step">
          <div class="step-dot">{s.dot}</div>
          <h5>{s.h}</h5>
          <p>{s.p}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process-three {
    grid-template-columns: repeat(3, 1fr);
  }
  .process-three::before {
    left: 16.66%;
    right: 16.66%;
  }

  @media (max-width: 900px) {
    .process-three {
      grid-template-columns: 1fr;
    }
    .process-three::before {
      display: none;
    }
  }
</style>

---
const stats = [
  {
    label: 'One-stop Service',
    sub: 'Checkup, TCM heritage therapies and culture travel in one standardized journey from inquiry to departure.',
    icon: '<path d="M4 7h16M4 12h16M4 17h16"/><path d="M8 4v16M16 4v16"/>',
  },
  {
    label: 'Authoritative Partners',
    sub: 'Cooperation with Class III hospital international departments, efficient checkups and expert interpretation.',
    icon: '<path d="M3 21h18M5 21V7l7-4 7 4v14"/><path d="M9 10h6M9 14h6M12 7v10"/>',
  },
  {
    label: 'Low and Transparent Price',
    sub: 'High value, all-inclusive quotations and no hidden charges during the trip.',
    icon: '<path d="M20 6 9 17l-5-5"/><path d="M15 6h5v5"/><path d="M4 19h16"/>',
  },
];
---

<section class="stats-dark" id="why-choose-us">
  <div class="container">
    <div class="stats-head">
      <span class="micro">Why Choose Us</span>
      <h2>Why Choose Us</h2>
    </div>
    <div class="stats-dark-grid">
      {stats.map((s) => (
        <div class="stat-dark">
          <span class="stat-icon-circle">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
          </span>
          <div class="label">{s.label}</div>
          <div class="sub">{s.sub}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats-dark {
    background: #fff;
    padding: 118px 0 88px;
    position: relative;
    z-index: 1;
  }
  .stats-head {
    margin-bottom: 44px;
  }
  .stats-head h2 {
    max-width: 720px;
    color: var(--ink);
    font-family: 'Inter', -apple-system, sans-serif;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.18;
    font-weight: 900;
  }
  .stats-dark-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }
  .stat-dark {
    min-height: 280px;
    padding: 34px 28px;
    background: #fff;
    border: 1px solid var(--hairline);
    border-radius: 10px;
    box-shadow: 0 12px 30px rgba(7, 27, 99, 0.04);
  }
  .stat-icon-circle {
    width: 70px;
    height: 70px;
    border-radius: 18px;
    background: #FFF2EA;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--seal);
    margin-bottom: 30px;
  }
  .stat-dark .label {
    margin-top: 0;
    font-size: 18px;
    color: var(--ink);
    font-weight: 900;
    letter-spacing: 0;
  }
  .stat-dark .sub {
    margin-top: 12px;
    font-size: 15px;
    color: var(--ink-soft);
    line-height: 1.55;
  }

  @media (max-width: 1000px) {
    .stats-dark-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .stats-dark { padding: 64px 0; }
    .stats-dark-grid { grid-template-columns: 1fr; }
    .stat-dark { min-height: auto; }
  }
</style>

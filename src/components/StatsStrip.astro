---
const stats = [
  {
    num: '50', sup: '+', label: 'Hospital Credentials', sub: 'JCI and Class III Tier A partner network',
    icon: '<path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h.01M15 9h.01M9 13h.01M15 13h.01M9 17h.01M15 17h.01"/>',
  },
  {
    num: '100', sup: '%', label: 'Privacy Protection', sub: 'Strict medical data handling and consent flow',
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>',
  },
  {
    num: '24/7', sup: '', label: 'Insurance-aware Support', sub: 'Pre-trip documentation and claim material guidance',
    icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>',
  },
  {
    num: '10', sup: '+', label: 'Reputable Travel Partners', sub: 'Screened wellness institutions and licensed agencies',
    icon: '<circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20"/>',
  },
];
---

<section class="stats-dark" id="trust-safety">
  <div class="container">
    <div class="stats-head">
      <span class="micro">Trust & Safety</span>
      <h2>Core Credentials</h2>
    </div>
    <div class="stats-dark-grid">
      {stats.map((s) => (
        <div class="stat-dark">
          <span class="stat-icon-circle">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
          </span>
          <div class="num">{s.num}<sup>{s.sup}</sup></div>
          <div class="label">{s.label}</div>
          <div class="sub">{s.sub}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats-dark {
    background: #fff;
    padding: 118px 0 88px;
    position: relative;
    z-index: 1;
  }
  .stats-head {
    margin-bottom: 44px;
  }
  .stats-head h2 {
    max-width: 720px;
    color: var(--ink);
    font-family: 'Inter', -apple-system, sans-serif;
    font-size: clamp(32px, 4vw, 48px);
    line-height: 1.18;
    font-weight: 900;
  }
  .stats-dark-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 22px;
  }
  .stat-dark {
    min-height: 280px;
    padding: 34px 28px;
    background: #fff;
    border: 1px solid var(--hairline);
    border-radius: 10px;
    box-shadow: 0 12px 30px rgba(7, 27, 99, 0.04);
  }
  .stat-icon-circle {
    width: 70px;
    height: 70px;
    border-radius: 18px;
    background: #FFF2EA;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--seal);
    margin-bottom: 30px;
  }
  .stat-dark .num {
    font-family: 'Inter', -apple-system, sans-serif;
    font-weight: 900;
    font-size: 42px;
    color: var(--ink);
    line-height: 1;
    letter-spacing: 0;
  }
  .stat-dark .num sup {
    font-size: 17px;
    color: var(--seal);
    vertical-align: super;
    margin-left: 2px;
  }
  .stat-dark .label {
    margin-top: 16px;
    font-size: 18px;
    color: var(--ink);
    font-weight: 900;
    letter-spacing: 0;
  }
  .stat-dark .sub {
    margin-top: 12px;
    font-size: 15px;
    color: var(--ink-soft);
    line-height: 1.55;
  }

  @media (max-width: 1000px) {
    .stats-dark-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .stats-dark { padding: 64px 0; }
    .stats-dark-grid { grid-template-columns: 1fr; }
    .stat-dark { min-height: auto; }
  }
</style>

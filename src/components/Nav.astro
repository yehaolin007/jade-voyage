---
import { nav } from '../data/site';
---

<nav class="top">
  <div class="container row">
    <a href="/" class="brand">
      <span class="seal">玉</span>
      <span class="brand-text">
        <span class="en">Jade Voyage</span>
        <span class="cn-mini">玉 行</span>
      </span>
    </a>
    <div class="nav-links">
      {nav.map((l) => (
        <a href={l.href} class={l.hasSub ? 'has-sub' : ''}>{l.label}</a>
      ))}
    </div>
    <div class="nav-actions">
      <button class="nav-search" aria-label="Search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" />
        </svg>
      </button>
      <button class="lang-toggle" data-lang-toggle aria-label="Language">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
          <circle cx="12" cy="12" r="9" /><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18" />
        </svg>
        <span class="lang-pair"><span data-lang-en class="on">EN</span><span class="sep">/</span><span data-lang-cn>CN</span></span>
      </button>
      <a href="/contact" class="btn btn-primary nav-cta">Book Consultation</a>
    </div>
  </div>
</nav>

<style>
  .nav-actions { display: flex; align-items: center; gap: 14px; }
  .nav-search {
    width: 36px; height: 36px;
    display: flex; align-items: center; justify-content: center;
    color: var(--ink-soft);
    border-radius: 50%;
    transition: background 0.2s, color 0.2s;
  }
  .nav-search:hover { background: var(--mist); color: var(--jade-deep); }
  .lang-toggle {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 6px 12px;
    border: 1px solid var(--hairline);
    border-radius: 9999px;
    color: var(--ink-soft);
    font-size: 12px;
    letter-spacing: 0.08em;
    transition: border-color 0.2s, color 0.2s;
  }
  .lang-toggle:hover { border-color: var(--jade); color: var(--jade-deep); }
  .lang-pair { display: inline-flex; align-items: center; gap: 4px; font-weight: 500; }
  .lang-pair .sep { color: var(--hairline); }
  .lang-pair span:not(.sep) { opacity: 0.45; transition: opacity 0.2s, color 0.2s; }
  .lang-pair span.on { opacity: 1; color: var(--ink); }
  .nav-cta { padding: 10px 18px; font-size: 13px; }
  @media (max-width: 900px) {
    .nav-search { display: none; }
    .lang-toggle { padding: 5px 10px; font-size: 11px; }
    .nav-cta { padding: 8px 14px; font-size: 12px; }
  }
</style>

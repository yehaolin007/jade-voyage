---
---

<section class="cta-band" id="contact">
  <div class="container cta-layout">
    <div class="cta-collage" aria-hidden="true">
      <img class="tile tile-small" src="/assets/hangzhou-westlake-retreat.png" alt="" loading="lazy" />
      <img class="tile tile-small" src="/assets/sichuan-hot-spring.png" alt="" loading="lazy" />
      <img class="tile tile-tall" src="/assets/huangshan-cultural-trek.png" alt="" loading="lazy" />
    </div>
    <div class="cta-copy">
      <span class="micro">Limited Concierge Intake</span>
      <h2>Plan a calmer China journey with <em>expert support</em> from day one.</h2>
      <p>Reach a real concierge, not a chatbot. We respond in English, German, French or Mandarin, typically within four hours.</p>
      <a href="/contact" class="btn btn-primary">Request a Custom Proposal</a>
      <div class="reply">WhatsApp +86 (0) 138-0000-0000 · hello@harmonyretreats.com</div>
    </div>
  </div>
</section>

<style>
  .cta-band {
    position: relative;
    padding: 104px 0;
    color: var(--ink);
    overflow: hidden;
    background:
      linear-gradient(90deg, rgba(255, 246, 241, 0.96), rgba(255, 255, 255, 0.92)),
      repeating-linear-gradient(60deg, rgba(7, 27, 99, 0.035) 0 1px, transparent 1px 28px);
  }
  .cta-band::before,
  .cta-band::after {
    display: none;
    content: none;
  }
  .cta-layout {
    display: grid;
    grid-template-columns: minmax(420px, 0.95fr) minmax(0, 1fr);
    gap: 64px;
    align-items: center;
    max-width: 1260px;
  }
  .cta-collage {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    min-height: 520px;
  }
  .cta-collage .tile {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 10px;
    box-shadow: 0 18px 42px rgba(7, 27, 99, 0.12);
    transform: translate3d(var(--mx, 0), var(--my, 0), 0) scale(1.01);
    transition: transform 1.1s cubic-bezier(.2,.7,.2,1), filter 0.45s, box-shadow 0.3s;
  }
  .cta-collage .tile:hover {
    transform: translate3d(var(--mx, 0), var(--my, 0), 0) scale(1.045);
    filter: saturate(1.05) brightness(1.03);
    box-shadow: 0 24px 52px rgba(7, 27, 99, 0.16);
  }
  .cta-collage .tile-small { height: 250px; }
  .cta-collage .tile-small:nth-child(2) { align-self: end; }
  .cta-collage .tile-tall {
    grid-row: 1 / span 2;
    grid-column: 2;
  }
  .cta-copy h2 {
    max-width: 720px;
    font-family: 'Inter', -apple-system, sans-serif;
    font-weight: 900;
    font-size: clamp(38px, 4.2vw, 56px);
    line-height: 1.18;
    margin: 12px 0 24px;
    color: var(--ink);
    text-align: left;
  }
  .cta-copy h2 em {
    color: var(--seal);
    font-style: normal;
  }
  .cta-copy p {
    max-width: 620px;
    margin: 0 0 32px;
    color: var(--ink-soft);
    font-size: 19px;
    line-height: 1.65;
    text-align: left;
  }
  .cta-band .btn-primary {
    background: var(--seal);
    color: #fff;
    padding: 17px 26px;
    font-weight: 900;
  }
  .cta-band .btn-primary:hover { background: var(--jade-deep); }
  .cta-band .reply {
    margin-top: 22px;
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  @media (max-width: 1000px) {
    .cta-layout { grid-template-columns: 1fr; }
    .cta-collage { min-height: 380px; }
  }

  @media (max-width: 640px) {
    .cta-band { padding: 64px 0; }
    .cta-collage { grid-template-columns: 1fr; min-height: 0; }
    .cta-collage .tile-tall { grid-row: auto; grid-column: auto; height: 260px; }
    .cta-collage .tile-small { height: 220px; }
  }
</style>

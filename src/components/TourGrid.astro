---
import { getCollection } from 'astro:content';
import TourCard from './TourCard.astro';

const entries = (await getCollection('tours', ({ data }) => data.featured))
  .sort((a, b) => a.data.order - b.data.order);
---

<section class="tours" id="tours">
  <div class="container">
    <div class="section-head-flex">
      <div class="section-head" style="margin-bottom: 0;">
        <span class="micro">Featured Packages</span>
        <h2>Chongqing wellness packages</h2>
        <p class="deck">Clear package routes that combine checkups, TCM heritage therapies and mountain-city travel, all supported by one concierge.</p>
      </div>
      <a href="/tours/" class="btn btn-outline">View All Packages</a>
    </div>

    <div class="tours-grid">
      {entries.map((entry) => <TourCard entry={entry} />)}
    </div>
  </div>
</section>

<style>
  .section-head .deck {
    max-width: 620px;
    margin-top: 14px;
  }
  .tours :global(.btn-outline) {
    background: #fff;
    border-color: var(--hairline);
    color: var(--ink);
    font-weight: 800;
  }
  .tours :global(.btn-outline:hover) {
    background: var(--seal);
    border-color: var(--seal);
    color: #fff;
  }
</style>

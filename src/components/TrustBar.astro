---
const trusts = [
  {
    name: 'JCI Accredited',
    meta: 'Joint Commission Intl.',
    icon: '<path d="M12 2L4 5v7c0 5 3.5 9 8 10 4.5-1 8-5 8-10V5l-8-3z"/><path d="M9 12l2 2 4-4"/>',
  },
  {
    name: 'Class III · Tier A',
    meta: '三甲医院合作',
    icon: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  },
  {
    name: 'CNATCM Licensed',
    meta: 'Chinese Medicine Board',
    icon: '<path d="M3 12l9-9 9 9M5 10v10h4v-6h6v6h4V10"/>',
  },
  {
    name: 'AAAAA Travel',
    meta: 'National Top-Rated',
    icon: '<path d="M12 2l3 6 7 1-5 5 1 7-6-3-6 3 1-7-5-5 7-1z"/>',
  },
];
---

<section class="trust" id="trust">
  <div class="container">
    <div class="trust-head">
      <span class="micro">— Verified Partners</span>
      <h3>Every journey is held to international standards.</h3>
    </div>
    <div class="trust-grid">
      {trusts.map((t) => (
        <div class="trust-cell">
          <div class="tc-mark">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" set:html={t.icon} />
          </div>
          <div class="tc-name">{t.name}</div>
          <div class="tc-meta">{t.meta}</div>
        </div>
      ))}
    </div>
    <p class="trust-foot">All medical, wellness and travel partners verified annually. <a href="#">View accreditation documents →</a></p>
  </div>
</section>

---
const trusts = [
  { name: 'JCI Accredited', meta: 'Joint Commission Intl.' },
  { name: 'Class III Tier A', meta: 'Hospital Partners' },
  { name: 'CNATCM Licensed', meta: 'Chinese Medicine Board' },
  { name: 'AAAAA Travel', meta: 'National Top-Rated' },
];
---

<section class="trust" id="trust">
  <div class="container">
    <div class="trust-strip">
      {trusts.map((t) => (
        <div class="trust-logo">
          <span>{t.name}</span>
          <small>{t.meta}</small>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust {
    background: #fff;
    padding: 42px 0;
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .trust-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    align-items: center;
  }
  .trust-logo {
    min-height: 74px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: rgba(7, 27, 99, 0.45);
    text-align: center;
    filter: grayscale(1);
  }
  .trust-logo span {
    font-size: 22px;
    font-weight: 900;
    letter-spacing: -0.02em;
  }
  .trust-logo small {
    margin-top: 4px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .trust-strip { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 520px) {
    .trust-strip { grid-template-columns: 1fr; }
  }
</style>

---
import type { PackageProduct } from '../data/packages';

export interface Props {
  product: PackageProduct;
}
const { product: p } = Astro.props;
const priceStr = p.priceFrom.toLocaleString('en-US');
const pairStr = p.pairPrice?.toLocaleString('en-US');
const href = '/contact';
---

<article class="tour-card pkg-card" data-group={p.group}>
  <a href={href} class="tour-img pkg-img">
    <img src={p.image} alt={p.alt} loading="lazy" />
    <span class="pkg-badge" data-group={p.group}>{p.badgeLabel}</span>
  </a>
  <div class="pkg-body">
    <div class="pkg-meta">
      <span class="pkg-region">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        {p.region}
      </span>
      <span class="pkg-dot">·</span>
      <span class="pkg-nights">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        {p.duration}
      </span>
    </div>
    <h3 class="pkg-title"><a href={href}>{p.title}</a></h3>
    <p class="pkg-cn">「{p.cnTitle}」</p>
    <ul class="pkg-highlights">
      {p.highlights.map((h, i) => (
        <li class={i === 0 ? 'h-primary' : ''}>{h}</li>
      ))}
    </ul>
    <div class="pkg-footer">
      <div class="pkg-price">
        <span class="from">Starting from</span>
        <div><span class="amount">${priceStr}</span><span class="per"> / person</span></div>
        {pairStr
          ? <span class="pair-price"><span>Two travelers</span> ${pairStr}</span>
          : p.pairNote && <span class="pair-price">{p.pairNote}</span>}
      </div>
      <a href={href} class="pkg-cta">Enquire →</a>
    </div>
  </div>
</article>

<style>
  .pkg-card .pkg-title a { color: inherit; text-decoration: none; }
  .pkg-card .pkg-title a:hover { color: var(--orange); }

  .pkg-badge {
    position: absolute;
    top: 14px;
    left: 14px;
    padding: 7px 14px;
    border-radius: 9999px;
    font-size: 10.5px;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: #fff;
    z-index: 2;
    backdrop-filter: blur(8px);
    box-shadow: 0 8px 20px rgba(7, 27, 99, 0.16);
    border: 1px solid rgba(255, 255, 255, 0.16);
  }
  .pkg-badge[data-group='wellness'] { background: rgba(241, 90, 36, 0.95); }
  .pkg-badge[data-group='medical'] { background: rgba(7, 27, 99, 0.95); }

  .pkg-body {
    padding: 22px 22px 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .pkg-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--navy-soft);
    margin-bottom: 12px;
    flex-wrap: wrap;
  }
  .pkg-region, .pkg-nights {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-weight: 700;
  }
  .pkg-dot { color: var(--hairline); }

  .pkg-title {
    font-family: 'Inter', -apple-system, sans-serif;
    font-size: 20px;
    font-weight: 800;
    line-height: 1.28;
    color: var(--navy);
    margin: 0;
  }
  .pkg-cn {
    font-family: 'Noto Serif SC', serif;
    font-size: 13.5px;
    color: var(--muted);
    letter-spacing: 0.04em;
    margin: 6px 0 0;
  }

  .pkg-highlights {
    list-style: none;
    padding: 0;
    margin: 16px 0 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }
  .pkg-highlights li {
    position: relative;
    padding-left: 16px;
    font-size: 13px;
    color: var(--navy-soft);
    line-height: 1.5;
  }
  .pkg-highlights li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--orange);
  }
  .pkg-highlights li.h-primary {
    color: var(--navy);
    font-weight: 800;
  }

  .pkg-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 18px;
    border-top: 1px solid var(--hairline);
    gap: 12px;
  }
  .pkg-price .from {
    display: block;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 2px;
  }
  .pkg-price .amount {
    font-family: 'Inter', -apple-system, sans-serif;
    font-size: 24px;
    font-weight: 900;
    color: var(--orange);
    font-variant-numeric: tabular-nums;
  }
  .pkg-price .per { font-size: 12px; color: var(--muted); }
  .pair-price {
    display: block;
    margin-top: 2px;
    color: var(--navy-soft);
    font-size: 11px;
    font-weight: 800;
  }

  .pkg-cta {
    display: inline-flex;
    align-items: center;
    padding: 10px 16px;
    border-radius: 8px;
    border: 1px solid var(--orange);
    color: var(--orange);
    font-size: 13px;
    font-weight: 800;
    white-space: nowrap;
    transition: background 0.2s, color 0.2s, transform 0.15s;
  }
  .pkg-cta:hover {
    background: var(--orange);
    color: #fff;
    transform: translateX(2px);
  }

  @media (max-width: 640px) {
    .pkg-meta {
      align-items: flex-start;
      flex-direction: column;
      gap: 6px;
    }
    .pkg-dot { display: none; }
    .pkg-cta {
      justify-content: center;
      width: 100%;
    }
  }
</style>

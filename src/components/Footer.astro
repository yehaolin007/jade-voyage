---
import { site } from '../data/site';

const cols = [
  {
    title: 'Packages',
    links: [
      { label: 'Featured Packages', href: '/#tours' },
      { label: 'Custom Travel', href: '/contact?service=Custom%20Travel' },
      { label: 'Checkup Services', href: '/#services' },
      { label: 'TCM Wellness', href: '/#services' },
      { label: 'All Packages', href: '/tours/' },
    ],
  },
  {
    title: 'Trust',
    links: [
      { label: 'Accredited Hospitals', href: '/verified-partners#medical' },
      { label: 'Wellness Clinics', href: '/verified-partners#wellness' },
      { label: 'Travel Partners', href: '/verified-partners#travel' },
      { label: 'Privacy Policy', href: '/verified-partners#privacy-policy' },
      { label: 'Refund Policy', href: '/contact' },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'Why Choose Us', href: '/#why-choose-us' },
      { label: 'Our Team', href: '/about' },
      { label: 'Real Stories', href: '/#stories' },
      { label: 'Press', href: '/contact' },
      { label: 'Contact', href: '/contact' },
    ],
  },
];
---

<footer>
  <div class="container">
    <div class="foot-grid">
      <div>
        <div class="foot-brand">
          <img src="/assets/harmony-icon-orange.svg" alt="Harmony Retreats logo" class="seal-img" />
          <span class="en">{site.brand}</span>
        </div>
        <p class="foot-tag">Harmony Retreats · {site.brandCn}</p>
        <div class="foot-contact">
          Chongqing · Shanghai · Hangzhou<br />
          <a href={`mailto:${site.email}`}>{site.email}</a><br />
          <a href={`https://wa.me/${site.whatsapp.replace(/[^0-9]/g, '')}`}>WhatsApp {site.whatsapp}</a>
        </div>
      </div>
      {cols.map((c) => (
        <div class="foot-col">
          <h6>{c.title}</h6>
          <ul>
            {c.links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
          </ul>
        </div>
      ))}
    </div>
    <div class="foot-bottom">
      <span>© 2026 Harmony Retreats Ltd. All rights reserved.</span>
      <div class="foot-payments">
        <span style="font-size: 11px; opacity: 0.6; letter-spacing: 0.1em;">SECURE PAYMENTS</span>
        <span class="pp">PayPal</span>
        <span class="pp">Visa</span>
        <span class="pp">Mastercard</span>
        <span class="pp">Amex</span>
      </div>
    </div>
  </div>
</footer>

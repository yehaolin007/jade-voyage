---
const items = [
  {
    icon: '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>',
    h: 'One concierge, end to end.',
    p: 'From your first inquiry to your return flight, a single bilingual concierge accompanies your file with no handoffs.',
  },
  {
    icon: '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>',
    h: 'Hospital-grade, hospitality-led.',
    p: 'We partner with JCI-accredited hospitals and Class III Tier-A facilities, paired with five-star recovery accommodations.',
  },
  {
    icon: '<path d="M12 2 15.09 8.26 22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>',
    h: 'Quietly luxurious, never loud.',
    p: 'Boutique hotels, small groups and itineraries that respect the slowness Chinese landscape was designed for.',
  },
  {
    icon: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
    h: 'Honest about outcomes.',
    p: 'We share medical and wellness results plainly, with credentialed care and verifiable practitioners.',
  },
];
---

<section id="about" class="why-section">
  <div class="container why-layout">
    <div class="why-left">
      <span class="micro">Why Harmony Retreats</span>
      <h2>Built on fifteen years of careful relationships.</h2>

      <div class="why-list">
        {items.map((i) => (
          <div class="why-row">
            <span class="why-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={i.icon} />
            </span>
            <div class="why-text">
              <h4>{i.h}</h4>
              <p>{i.p}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="why-right">
      <div class="why-image-wrap">
        <img src="/assets/story-concierge-lounge.png" alt="A Harmony Retreats concierge in a serene lounge setting" loading="lazy" />
      </div>
      <div class="why-caption">
        <strong>15+ Years</strong>
        <span>Attentive concierge service across China</span>
      </div>
    </div>
  </div>
</section>

<style>
  .why-section { background: var(--canvas); }
  .why-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: center;
  }
  .why-left .micro { color: var(--seal); margin-bottom: 16px; display: inline-block; }
  .why-left h2 {
    font-family: 'Inter', -apple-system, sans-serif;
    font-weight: 900;
    font-size: clamp(34px, 4vw, 50px);
    line-height: 1.18;
    letter-spacing: 0;
    color: var(--ink);
    margin-bottom: 42px;
  }
  .why-list { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
  .why-row {
    min-height: 230px;
    padding: 28px;
    background: #fff;
    border: 1px solid var(--hairline);
    border-radius: 10px;
  }
  .why-icon {
    width: 62px;
    height: 62px;
    border-radius: 16px;
    background: #FFF2EA;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--seal);
    margin-bottom: 26px;
  }
  .why-text h4 {
    font-family: 'Inter', -apple-system, sans-serif;
    font-weight: 900;
    font-size: 20px;
    color: var(--ink);
    margin: 0 0 10px;
    line-height: 1.28;
  }
  .why-text p {
    font-size: 15px;
    color: var(--ink-soft);
    line-height: 1.62;
  }
  .why-right { position: relative; }
  .why-image-wrap {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: var(--shadow-lift);
  }
  .why-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.05) brightness(1.02);
  }
  .why-caption {
    position: absolute;
    top: 32px;
    right: -16px;
    background: var(--seal);
    color: #fff;
    padding: 20px 24px;
    border-radius: 10px;
    box-shadow: 0 18px 36px rgba(241, 90, 36, 0.22);
    max-width: 220px;
  }
  .why-caption strong {
    display: block;
    font-size: 28px;
    font-weight: 900;
    margin-bottom: 4px;
    line-height: 1;
  }
  .why-caption span {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.84);
    line-height: 1.4;
  }

  @media (max-width: 1000px) {
    .why-layout { grid-template-columns: 1fr; }
    .why-right { order: -1; }
  }

  @media (max-width: 640px) {
    .why-list { grid-template-columns: 1fr; }
    .why-image-wrap { aspect-ratio: 16 / 11; }
    .why-caption {
      top: auto;
      bottom: -16px;
      right: 16px;
      padding: 14px 18px;
    }
  }
</style>

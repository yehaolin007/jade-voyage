---
const items = [
  { num: '— 01', h: 'One concierge, end to end.', p: 'From your first inquiry to your return flight, a single bilingual concierge accompanies your file — no handoffs, no relayed questions.' },
  { num: '— 02', h: 'Hospital-grade, hospitality-led.', p: 'We partner only with JCI-accredited hospitals and Class III Tier-A facilities, paired with five-star recovery accommodations.' },
  { num: '— 03', h: 'Quietly luxurious, never loud.', p: 'Boutique hotels, small groups (under 8 guests), and itineraries that respect the slowness Chinese landscape was designed for.' },
  { num: '— 04', h: 'Honest about outcomes.', p: 'We share medical and wellness results plainly. No promises of cures — only credentialed care and verifiable practitioners.' },
];
---

<section id="about">
  <div class="container">
    <div class="section-head">
      <span class="micro">— Why Jade Voyage</span>
      <h2>Built on fifteen years of careful relationships.</h2>
      <div class="underline"></div>
    </div>

    <div class="why-grid">
      {items.map((i) => (
        <div class="why-item">
          <span class="num">{i.num}</span>
          <h4>{i.h}</h4>
          <p>{i.p}</p>
        </div>
      ))}
    </div>
  </div>
</section>

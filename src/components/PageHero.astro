---
export interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  bgImage?: string;
  crumbs?: { label: string; href?: string }[];
}
const { eyebrow, title, subtitle, bgImage, crumbs = [] } = Astro.props;
---

<header class="page-hero" data-has-bg={bgImage ? 'true' : 'false'}>
  {bgImage && <div class="page-hero-bg" style={`background-image: url('${bgImage}')`}></div>}
  <div class="page-hero-overlay"></div>
  <div class="container">
    {crumbs.length > 0 && (
      <nav class="crumbs" aria-label="Breadcrumb">
        {crumbs.map((c, i) => (
          <>
            {c.href ? <a href={c.href}>{c.label}</a> : <span>{c.label}</span>}
            {i < crumbs.length - 1 && <span class="sep">/</span>}
          </>
        ))}
      </nav>
    )}
    {eyebrow && <span class="micro page-hero-eyebrow">— {eyebrow}</span>}
    <h1>{title}</h1>
    {subtitle && <p class="page-hero-sub">{subtitle}</p>}
  </div>
</header>

<style>
  .page-hero {
    position: relative;
    padding: 120px 0 72px;
    background: var(--ink);
    color: var(--canvas);
    overflow: hidden;
  }
  .page-hero[data-has-bg='false'] {
    background: linear-gradient(135deg, #1F3A36 0%, #2B4A45 60%, #4F7568 100%);
  }
  .page-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: saturate(0.88) brightness(0.85);
    z-index: 0;
  }
  .page-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(15,28,26,0.45) 0%, rgba(15,28,26,0.75) 100%);
    z-index: 1;
  }
  .page-hero .container { position: relative; z-index: 2; max-width: 1080px; margin: 0 auto; padding: 0 32px; }
  .crumbs {
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.78;
    margin-bottom: 18px;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .crumbs a { text-decoration: none; color: inherit; }
  .crumbs a:hover { color: #E8C77A; }
  .crumbs .sep { opacity: 0.5; }
  .page-hero-eyebrow {
    color: #E8C77A !important;
    letter-spacing: 0.18em;
    display: block;
    margin-bottom: 16px;
  }
  .page-hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-size: clamp(40px, 5.5vw, 64px);
    line-height: 1.05;
    letter-spacing: -0.015em;
    max-width: 820px;
    margin: 0 0 18px;
  }
  .page-hero-sub {
    font-size: 18px;
    max-width: 620px;
    line-height: 1.55;
    opacity: 0.9;
    font-weight: 300;
  }
  @media (max-width: 768px) {
    .page-hero { padding: 80px 0 56px; }
  }
</style>

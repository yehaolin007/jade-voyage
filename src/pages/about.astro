---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import FloatChat from '../components/FloatChat.astro';
import PageHero from '../components/PageHero.astro';

const team = [
  {
    name: 'Lin Yuwen',
    role: 'Founder & Chief Concierge',
    bio: 'Fifteen years between hospital administration, cross-border guest care and bespoke travel design. Lin built Harmony Retreats around one practical promise: international guests should be able to combine checkups, TCM heritage therapies and Chongqing travel without friction.',
    img: '/assets/story-concierge-lounge.png',
  },
  {
    name: 'Dr. Chen Mei',
    role: 'Medical Director',
    bio: 'Internal medicine specialist with twenty years at a Class III tertiary hospital. Dr. Chen reviews partner standards, checkup logic and report interpretation workflows before guest arrival.',
    img: '/assets/clinic-executive-checkup.png',
  },
  {
    name: 'Master Wu Tianqing',
    role: 'TCM & Wellness Curator',
    bio: 'Licensed TCM wellness practitioner focused on heritage therapies, meridian care and practical recovery routines that guests can continue after returning home.',
    img: '/assets/sichuan-hot-spring.png',
  },
  {
    name: 'Sarah Whitmore',
    role: 'European Liaison',
    bio: 'Former luxury travel editor based in London. Sarah is the first voice many guests hear, speaking English, German and French, with a gift for translating wishes into concrete day-by-day plans.',
    img: '/assets/private-custom-planning.png',
  },
];

const principles = [
  { num: '01', h: 'One route, three services.', p: 'Checkup, TCM heritage therapies and cultural travel are planned as one coordinated service, not separate vendors stitched together late.' },
  { num: '02', h: 'Credentials, not claims.', p: 'Hospitals, clinics and travel partners are selected for visible qualifications and operational reliability.' },
  { num: '03', h: 'A single point of contact.', p: 'One concierge follows the file from inquiry to return, reducing repeated explanations and missed details.' },
  { num: '04', h: 'Clear pricing.', p: 'We prefer all-inclusive proposals, plain exclusions and no hidden consumption pressure during the trip.' },
];
---

<Layout title="About Harmony Retreats" description="A bilingual cross-border wellness travel team focused on Chongqing checkups, TCM heritage therapies and mountain-city experiences.">
  <Nav />

  <PageHero
    eyebrow="About Harmony Retreats"
    title="Cross-border wellness travel, held by one team."
    subtitle="Harmony Retreats coordinates checkups, TCM heritage therapies and Chongqing mountain-city experiences for international guests who want a clear, supported journey."
    bgImage="/assets/story-concierge-lounge.png"
    crumbs={[{ label: 'Home', href: '/' }, { label: 'About' }]}
  />

  <section class="about-story">
    <div class="container story-grid">
      <div>
        <span class="micro">Our Story</span>
        <h2>Built for guests who need clarity.</h2>
        <div class="underline"></div>
      </div>
      <div class="story-copy">
        <p>
          The idea behind Harmony Retreats is simple: international guests should not have to coordinate medical appointments, TCM wellness experiences, transport, translation and travel planning through five disconnected channels.
        </p>
        <p>
          We focus on Chongqing as a practical wellness base: strong hospital access, mountain-city culture, distinctive food, riverside movement and surrounding restorative routes. The concierge layer holds the plan together before, during and after the trip.
        </p>
        <p>
          We remain deliberately small. Each booking receives a named advisor, a clear package scope, visible partner standards and follow-up support after guests return home.
        </p>
      </div>
    </div>
  </section>

  <section class="about-principles">
    <div class="container">
      <div class="section-head">
        <span class="micro">Four Principles</span>
        <h2>What we will, and will not, do.</h2>
        <div class="underline"></div>
      </div>
      <div class="principles-grid">
        {principles.map((p) => (
          <div class="principle">
            <div class="p-num">{p.num}</div>
            <h4>{p.h}</h4>
            <p>{p.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="about-team">
    <div class="container">
      <div class="section-head">
        <span class="micro">Our Team</span>
        <h2>The people who actually answer your messages.</h2>
        <div class="underline"></div>
      </div>
      <div class="team-grid">
        {team.map((m) => (
          <article class="team-card">
            <div class="team-img"><img src={m.img} alt={m.name} loading="lazy" /></div>
            <div class="team-body">
              <h4>{m.name}</h4>
              <div class="team-role">{m.role}</div>
              <p>{m.bio}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <Footer />
  <FloatChat />
</Layout>

<style>
  .about-story { padding: 96px 0; background: var(--canvas); }
  .story-grid { display: grid; grid-template-columns: 1fr 1.6fr; gap: 64px; align-items: start; }
  .about-story .micro { color: var(--seal); margin-bottom: 14px; display: inline-block; }
  .about-story h2 {
    font-family: 'Inter', -apple-system, sans-serif;
    font-weight: 900;
    font-size: clamp(34px, 4vw, 48px);
    color: var(--ink);
    line-height: 1.12;
  }
  .underline { width: 40px; height: 2px; background: var(--seal); margin-top: 20px; }
  .story-copy p {
    color: var(--ink-soft);
    font-size: 17px;
    line-height: 1.7;
    margin-bottom: 18px;
  }
  .story-copy p:first-letter {
    font-size: 38px;
    color: var(--seal);
    float: left;
    line-height: 1;
    margin-right: 8px;
    margin-top: 4px;
    font-weight: 900;
  }

  .about-principles { padding: 96px 0; background: var(--rice); }
  .principles-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; }
  .principle {
    background: var(--canvas);
    padding: 32px;
    border-radius: 10px;
    border: 1px solid var(--hairline);
  }
  .p-num {
    font-size: 20px;
    color: var(--seal);
    margin-bottom: 14px;
    font-weight: 900;
  }
  .principle h4 {
    font-family: 'Inter', -apple-system, sans-serif;
    font-weight: 900;
    font-size: 22px;
    color: var(--ink);
    margin-bottom: 10px;
  }
  .principle p { color: var(--ink-soft); line-height: 1.6; font-size: 15px; }

  .about-team { padding: 96px 0; background: var(--canvas); }
  .team-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; }
  .team-card {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 24px;
    padding: 24px;
    background: var(--rice);
    border-radius: 10px;
    align-items: start;
  }
  .team-img { width: 100%; aspect-ratio: 1 / 1; overflow: hidden; border-radius: 10px; }
  .team-img img { width: 100%; height: 100%; object-fit: cover; display: block; filter: saturate(0.96); }
  .team-card h4 {
    font-family: 'Inter', -apple-system, sans-serif;
    font-weight: 900;
    font-size: 22px;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .team-role {
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--seal);
    margin-bottom: 12px;
    font-weight: 800;
  }
  .team-card p { color: var(--ink-soft); font-size: 14px; line-height: 1.6; }

  .section-head {
    margin-bottom: 56px;
    max-width: 720px;
  }
  .section-head .micro { color: var(--seal); margin-bottom: 14px; display: inline-block; }
  .section-head h2 {
    font-family: 'Inter', -apple-system, sans-serif;
    font-weight: 900;
    font-size: clamp(32px, 3.6vw, 46px);
    color: var(--ink);
    line-height: 1.14;
  }

  @media (max-width: 960px) {
    .story-grid { grid-template-columns: 1fr; gap: 32px; }
    .principles-grid, .team-grid { grid-template-columns: 1fr; }
    .team-card { grid-template-columns: 120px 1fr; }
  }
</style>

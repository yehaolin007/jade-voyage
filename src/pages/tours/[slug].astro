---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import FloatChat from '../../components/FloatChat.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { site } from '../../data/site';

type TourData = CollectionEntry<'tours'>['data'] & { slug: string };

export async function getStaticPaths() {
  const entries = await getCollection('tours');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { tour: { ...entry.data, slug: entry.slug } },
  }));
}

interface Props { tour: TourData }
const { tour } = Astro.props;

const city = tour.region.split(/[·+]/)[0].trim();
const title = `${tour.title}${tour.subtitle ? ' - ' + tour.subtitle : ''} | Harmony Retreats`;
const priceStr = tour.priceFrom.toLocaleString('en-US');
const adultPrice = tour.priceFrom;
const payBase = `https://www.paypal.me/${site.paypal.me}/`;
const payCurrency = site.paypal.currency;

const dayTemplates: Record<TourData['category'], string[]> = {
  Wellness: [
    'Arrival and private transfer. Settle into your lakeside hotel, meet your concierge, and begin with a quiet tea ceremony.',
    'Morning TCM diagnostic with a licensed physician, personal herbal formulation, and an easy lakeside walk.',
    'Acupuncture session, guided Tai Chi at dawn, and a vegetarian cuisine workshop.',
    'Hot-spring half-day, meridian massage, and afternoon at leisure in the garden pavilion.',
    'Optional day trip to a tea-mountain retreat, with calligraphy or Guqin class on return.',
    'Final consultation, take-home prescriptions translated, and farewell dinner.',
    'Private transfer to airport. Post-trip telehealth can be booked if requested.',
  ],
  Medical: [
    'Airport meet-and-greet and check-in at a quiet recovery hotel close to the partner hospital.',
    'Pre-screening intake, bloodwork, ECG, imaging, and specialist scheduling.',
    'Specialist consultations, results review, and English-language report preparation.',
    'Post-screening rest day with gentle city excursion or in-house recovery treatment.',
  ],
  Culture: [
    'Arrival, orientation walk, and cultural curator briefing over a regional welcome dinner.',
    'Early sunrise expedition, heritage site tour, and regional cuisine dinner.',
    'Craft workshop, artisan visit, and afternoon hiking with a bilingual guide.',
    'Off-the-grid village stay and twilight meditation by ancient pine.',
    'Museum and private gallery access with curator-led conversation.',
    'Slow morning, optional photography session, and seasonal banquet.',
  ],
  Bespoke: [
    'Arrival by private vehicle, meeting with the route designer, and welcome banquet.',
    'Ancient Tea Horse Road segment, post-station stay, and regional cuisine.',
    'Forest soak and herbalist consultation among Pu-erh terraces.',
    'Optional Naxi music evening or sound-bath practice in a temple courtyard.',
    'Day trek with mule porters, highland picnic, and stargazing camp.',
    'Craft village stay with indigo dye or silver work workshop.',
    'Concluding wellness review and home-practice plan.',
  ],
};

const renewalDetail = {
  summary: 'A 9-day deep wellness journey beginning with a Xueping Package 3 checkup in Chongqing, followed by advanced TCM therapy, heritage workshops, pure-play Sichuan-Chongqing travel, five-diamond hotels and oxygen-supported highland routing.',
  facts: [
    ['Duration', '9 days / 8 nights'],
    ['Route', 'Chongqing -> Chengdu -> Jiuzhaigou -> Huanglong -> Chengdu'],
    ['Hotels', 'Ctrip five-diamond hotels throughout'],
    ['Vehicle', 'Private 9-seat MPV'],
    ['Best for', 'Visa-free professionals, higher-income guests and deep wellness travelers'],
    ['Promise', 'No shopping · foreigner-friendly · altitude support · first-day checkup'],
  ],
  gallery: [
    '/assets/products/jiuzhaigou-valley.png',
    '/assets/products/chongqing-skyline.png',
    '/assets/products/tcm-massage.png',
    '/assets/products/herbal-bath.png',
    '/assets/products/hongyadong-night.png',
    '/assets/products/wulong-three-bridges.png',
    '/assets/products/huanglong-pools.png',
    '/assets/products/chengdu-taikooli.png',
  ],
  days: [
    { title: 'Arrival in Chongqing · deep checkup and wellness day', body: 'VIP airport or station pickup, Xueping Package 3 deep checkup covering thyroid, tumor markers and cardiac ultrasound, followed by advanced shoulder-neck therapy, herbal bath, moxibustion, wellness tea DIY and herbal sachet workshop.', meta: 'Meals: none · Stay: Chongqing five-diamond hotel', images: ['/assets/products/chongqing-skyline.png', '/assets/products/tcm-massage.png', '/assets/products/herbal-bath.png', '/assets/products/herbal-sachet.webp'] },
    { title: 'Chongqing city panorama · relaxed mountain-city day', body: 'Ciqikou, Liziba, Raffles City and Jiefangbei by day, then Bayi Food Street, Hongyadong and a Liangjiang night cruise in the evening.', meta: 'Meals: dinner · Stay: Chongqing five-diamond hotel', images: ['/assets/products/liziba-light-rail.png', '/assets/products/hongyadong-night.png', '/assets/products/liangjiang-cruise.png', '/assets/products/chongqing-skyline.png'] },
    { title: 'Chongqing to Wulong · natural wellness landscape day', body: 'Visit the Three Natural Bridges and Fairy Mountain with the scenic train, enjoy steamed-basket banquet and farmhouse cuisine, then return to Chongqing.', meta: 'Meals: breakfast / lunch / dinner · Stay: Chongqing five-diamond hotel', images: ['/assets/products/wulong-three-bridges.png', '/assets/products/wulong-fairy-mountain.png', '/assets/products/heritage-craft.png', '/assets/products/chongqing-skyline.png'] },
    { title: 'Chongqing to Chengdu · city transition day', body: 'Morning half-mountain walk at Eling Park, lunch, then a two-hour high-speed train to Chengdu. Check in to a five-diamond hotel and enjoy free time.', meta: 'Meals: breakfast / lunch · Stay: Chengdu five-diamond hotel', images: ['/assets/products/chongqing-skyline.png', '/assets/products/chengdu-taikooli.png', '/assets/products/kuanzhai-alley.png', '/assets/products/chengdu-airport.png'] },
    { title: 'Chengdu to Huanglong and Jiuzhaigou · altitude adaptation day', body: 'Travel from Chengdu to Huanglong with cableway access, continue to Jiuzhaigou, and receive altitude-adaptation guidance with oxygen support throughout.', meta: 'Meals: breakfast / lunch / dinner · Stay: Jiuzhaigou five-diamond hotel', images: ['/assets/products/huanglong-pools.png', '/assets/products/jiuzhaigou-valley.png', '/assets/products/jiuzhaigou-lake.png', '/assets/products/jiuzhaigou-autumn.png'] },
    { title: 'Jiuzhaigou · full-day nature therapy', body: 'Explore Shuzheng Valley, Rize Valley and Zechawa Valley with sightseeing vehicle access. End the day with Tibetan hotpot.', meta: 'Meals: breakfast / dinner · Stay: Jiuzhaigou five-diamond hotel', images: ['/assets/products/jiuzhaigou-autumn.png', '/assets/products/jiuzhaigou-valley.png', '/assets/products/jiuzhaigou-lake.png', '/assets/products/huanglong-pools.png'] },
    { title: 'Jiuzhaigou to Chengdu · culture night return', body: 'Return to Chengdu, visit Jinli, Taikoo Li, IFS and Kuanzhai Alley, then explore Fuqin Night Market and Chengdu snacks.', meta: 'Meals: breakfast / lunch / dinner · Stay: Chengdu five-diamond hotel', images: ['/assets/products/chengdu-taikooli.png', '/assets/products/kuanzhai-alley.png', '/assets/products/heritage-craft.png', '/assets/products/chengdu-airport.png'] },
    { title: 'Chengdu city · free wellness day', body: 'Morning hotel wellness recovery, afternoon creative-city walk and health recap, then a featured Sichuan dinner.', meta: 'Meals: breakfast / dinner · Stay: Chengdu five-diamond hotel', images: ['/assets/products/herbal-tea.jpeg', '/assets/products/neck-therapy.png', '/assets/products/chengdu-taikooli.png', '/assets/products/kuanzhai-alley.png'] },
    { title: 'Chengdu departure · trip completion', body: 'Breakfast, free time, then private transfer to Chengdu Shuangliu Airport for departure.', meta: 'Meals: breakfast · Stay: home', images: ['/assets/products/chengdu-airport.png', '/assets/products/chengdu-taikooli.png', '/assets/products/jiuzhaigou-valley.png', '/assets/products/chongqing-skyline.png'] },
  ],
  coreServices: [
    '8 nights in five-diamond hotels with daily breakfast',
    'Private 9-seat MPV throughout the land itinerary',
    'Chongqing-Chengdu high-speed rail, scheduled tickets and scenic transfers',
    'Dedicated English-speaking guide throughout',
    'Oxygen support and emergency handling for highland sections',
  ],
  included: [
    '8 nights in five-diamond hotels + daily breakfast',
    '12 featured meals including Jianghu cuisine, hotpot and Tibetan hotpot',
    '9-seat MPV, English-speaking guide and driver-guide gratuities',
    'High-speed rail tickets, all scheduled entrance tickets and scenic shuttles',
    'Travel accident insurance, altitude support and 24-hour service desk',
  ],
  notIncluded: [
    'Round-trip international flights, visa fees and personal travel insurance',
    'Personal expenses, alcohol, shopping and optional purchases',
    'Single-room supplement and personal hotel expenses',
    'Optional entertainment items inside Fairy Mountain scenic area',
  ],
  safeguards: [
    'Pure-play guarantee: no shopping stops and no forced consumption',
    'Medical guarantee: tertiary checkup coordination and licensed therapists',
    'Altitude guarantee: oxygen support and emergency handling',
    'Language guarantee: English-speaking guide and bilingual report support',
    'Privacy guarantee: encrypted handling of health data',
  ],
  notes: [
    'Guests with hypertension or heart conditions should inform us before booking so the highland section can be assessed.',
    'Cancellation: full refund 20 days before departure, 50% refund 10-19 days before departure, non-refundable within 10 days.',
    'Passport information is required for checkup appointments, hotels and attraction tickets.',
  ],
};

const detail = tour.slug === 'executive-checkup-journey' ? renewalDetail : null;
const galleryPool = (detail?.gallery || [
  tour.image,
  '/assets/products/chongqing-skyline.png',
  '/assets/products/tcm-massage.png',
  '/assets/products/hongyadong-night.png',
  '/assets/products/herbal-sachet.webp',
]).filter((src, index, arr) => arr.indexOf(src) === index);
const genericDays = dayTemplates[tour.category]
  .slice(0, Math.min(tour.nights, dayTemplates[tour.category].length))
  .map((body, index) => ({
    title: index === 0 ? `${city} arrival` : tour.category,
    body,
    meta: '',
    images: galleryPool.slice(0, 4),
  }));
const days = detail?.days || genericDays;
const dayLabels = days.map((_, index) => `Day ${index + 1}`);
const inclusions = detail?.included || [
  'Bilingual concierge accompaniment throughout the journey',
  'Boutique accommodation and daily breakfast',
  'Private in-trip transfers',
  'Entrance fees to scheduled partner sites',
  'Medical or wellness consultations as listed',
  '24-hour support during your stay',
];
const notIncluded = detail?.notIncluded || [
  'International flights (we can arrange on request)',
  'Personal travel insurance (mandatory; partner referral available)',
  'Visa application fees (we provide invitation letters)',
  'Gratuities and personal shopping',
  'Optional add-on experiences priced separately',
];
const ticketOptions = tour.pairPrice
  ? [
      { name: 'Single traveler package', price: adultPrice, initial: 1 },
      { name: 'Two travelers package', price: tour.pairPrice, initial: 0 },
    ]
  : [
      { name: 'Adult package', price: adultPrice, initial: 1 },
      { name: 'Senior package', price: Math.round(tour.priceFrom * 1.1), initial: 0 },
      { name: 'Family package', price: Math.round(tour.priceFrom * 2.8), initial: 0 },
    ];
const imageRows = galleryPool.slice(0, 4);
---

<Layout title={title} description={`${tour.title} ${tour.subtitle || ''} product detail page.`}>
  <Nav />

  <main class="product-page">
    <section class="product-shell">
      <div class="container product-layout">
        <div class="product-main">
          <div class="product-intro">
            <div class="product-kicker">{tour.category} tour</div>
            <div class="title-row">
              <h1>{tour.title}{tour.subtitle && <span>{tour.subtitle}</span>}</h1>
              <a class="expand-link" href={tour.image} target="_blank" rel="noopener" aria-label="Open main image">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M21 14v7h-7"/><path d="M3 10V3h7"/><path d="M3 21l7-7"/></svg>
              </a>
            </div>
            <p class="summary">{detail?.summary || `Step into a curated ${tour.duration || `${tour.nights}-night`} journey in ${city}. Every day balances meaningful experiences, credentialed care, and quiet recovery, with a bilingual concierge holding the details from arrival to departure.`}</p>
            <div class="days-line">Trip length: <strong>{tour.duration || `${tour.nights} nights`}</strong></div>
            {detail?.facts && (
              <div class="fact-grid">
                {detail.facts.map(([label, value]) => (
                  <div class="fact-item">
                    <span>{label}</span>
                    <strong>{value}</strong>
                  </div>
                ))}
              </div>
            )}
          </div>

          <div class="product-gallery">
            <div class="main-image">
              <img src={tour.image} alt={tour.alt} loading="eager" />
            </div>
            <div class="thumb-row" aria-label="Tour image thumbnails">
              {galleryPool.slice(0, 5).map((src, index) => (
                <button class={`thumb ${index === 0 ? 'is-active' : ''}`} type="button" data-gallery-src={src}>
                  <img src={src} alt="" loading="lazy" />
                </button>
              ))}
            </div>
          </div>

          <section class="product-content">
            <nav class="detail-tabs" aria-label="Tour detail sections">
              <a href="#detail" class="active">Detail</a>
              {detail?.coreServices && <a href="#services">Core services</a>}
              <a href="#included">What's included</a>
              <a href="#not-included">Not included</a>
              {detail?.safeguards && <a href="#safeguards">Safeguards</a>}
              {detail?.notes && <a href="#notes">Booking notes</a>}
              <a href="#review">Review</a>
            </nav>

            <div id="detail" class="detail-copy">
              <h2>{tour.title} itinerary</h2>
              <p>
                {detail ? 'The full nine-day route is paced around first-day checkup and wellness care, then pure-play Chongqing, Chengdu, Huanglong and Jiuzhaigou travel with altitude support.' : 'This itinerary is designed for international guests who want a clear product-style tour while keeping the high-touch Harmony Retreats service layer. Timings can be adjusted, but the rhythm below shows how your days may unfold.'}
              </p>

              {days.map((day, index) => (
                <article class="day-section">
                  <h3><span>{dayLabels[index]}</span>: <span>{day.title}</span></h3>
                  <p>{day.body}</p>
                  {day.meta && <div class="day-meta">{day.meta}</div>}
                  <div class="image-table">
                    <div class="table-label">{day.title}</div>
                    {(day.images || imageRows).map((src) => (
                      <div class="table-img">
                        <img src={src} alt="" loading="lazy" />
                      </div>
                    ))}
                  </div>
                </article>
              ))}
            </div>

            {detail?.coreServices && (
              <div id="services" class="included-panel">
                <h2>Core services included</h2>
                <div class="included-grid">
                  {detail.coreServices.map((item) => <div class="included-item">{item}</div>)}
                </div>
              </div>
            )}

            <div id="included" class="included-panel">
              <h2>What's included</h2>
              <div class="included-grid">
                {inclusions.map((item) => <div class="included-item">{item}</div>)}
              </div>
            </div>

            <div id="not-included" class="included-panel">
              <h2>Not included</h2>
              <div class="included-grid">
                {notIncluded.map((item) => <div class="included-item">{item}</div>)}
              </div>
            </div>

            {detail?.safeguards && (
              <div id="safeguards" class="included-panel">
                <h2>Service safeguards</h2>
                <div class="included-grid">
                  {detail.safeguards.map((item) => <div class="included-item">{item}</div>)}
                </div>
              </div>
            )}

            {detail?.notes && (
              <div id="notes" class="included-panel">
                <h2>Booking notes and cancellation</h2>
                <div class="included-grid">
                  {detail.notes.map((item) => <div class="included-item">{item}</div>)}
                </div>
              </div>
            )}

            <div id="review" class="review-panel">
              <h2>Guest review</h2>
              <p>"Everything felt precise, but never rushed. The concierge made the medical and cultural parts feel like one continuous journey."</p>
              <strong>Rating {tour.rating.toFixed(2)} / 5.00 · {tour.reviews} reviews</strong>
            </div>
          </section>
        </div>

        <aside class="product-panel">
          <div class="booking-head">
            <span>Booking summary</span>
            <strong>From ${priceStr}</strong>
            <p class="booking-sub">Final quote confirmed by your concierge.</p>
          </div>

          <div class="booking-field">
            <label>Check-in date</label>
            <input type="date" class="booking-input" />
          </div>
          <div class="booking-field">
            <label>Check-out</label>
            <input type="date" class="booking-input" />
          </div>

          <div class="booking-section">
            <h3>Ticket type</h3>
            {ticketOptions.map((ticket) => (
              <div class="ticket-row" data-ticket-row data-unit-price={ticket.price}>
                <span class="ticket-name">{ticket.name}</span>
                <span class="ticket-price">${ticket.price.toLocaleString('en-US')}</span>
                <div class="quantity-stepper" data-qty>
                  <button type="button" data-qty-minus aria-label="Decrease quantity">-</button>
                  <span data-qty-value>{ticket.initial}</span>
                  <button type="button" data-qty-plus aria-label="Increase quantity">+</button>
                </div>
              </div>
            ))}
          </div>

          <div class="booking-section">
            <h3>Add-on services</h3>
            <label class="addon-row" data-addon-row data-addon-price="320">
              <input type="checkbox" />
              <span class="addon-name">All in-trip transfers in private vehicles</span>
              <span class="addon-price">+$320</span>
            </label>
            <label class="addon-row" data-addon-row data-addon-price="80">
              <input type="checkbox" />
              <span class="addon-name">24-hour medical hotline during your stay</span>
              <span class="addon-price">+$80</span>
            </label>
            <label class="addon-row" data-addon-row data-addon-price="150">
              <input type="checkbox" />
              <span class="addon-name">Daily breakfast + curated regional dining experiences</span>
              <span class="addon-price">+$150</span>
            </label>
          </div>

          <div class="booking-total">
            <span>Total estimate</span>
            <strong data-total-display>${priceStr}</strong>
          </div>
          <a class="book-btn" href={`${payBase}${adultPrice}${payCurrency}`} data-pay-link data-pay-base={payBase} data-pay-currency={payCurrency} target="_blank" rel="noopener">Book Now</a>
          <p class="booking-note">No deposit required to enquire. Custom adjustments welcome.</p>
        </aside>
      </div>
    </section>
  </main>

  <Footer />
  <FloatChat />
</Layout>

<style>
  .product-page {
    background: #fff;
    color: var(--ink);
  }
  .product-shell {
    padding: 46px 0 96px;
    background:
      linear-gradient(180deg, #fff 0%, #fff 56%, var(--sky-mist) 100%);
  }
  .product-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: clamp(36px, 4vw, 60px);
    align-items: start;
    max-width: 1500px;
  }
  .product-main {
    min-width: 0;
  }
  .product-intro {
    margin-bottom: 28px;
    padding: 4px 0 6px;
  }
  .product-gallery {
    min-width: 0;
  }
  .main-image {
    aspect-ratio: 16 / 10.5;
    background: #f3f4f6;
    overflow: hidden;
    border-radius: 10px;
    box-shadow: 0 18px 46px rgba(7, 27, 99, 0.1);
  }
  .main-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: translate3d(var(--mx, 0), var(--my, 0), 0) scale(1.01);
    transition: transform 0.8s cubic-bezier(.2,.7,.2,1);
  }
  .main-image:hover img {
    transform: translate3d(var(--mx, 0), var(--my, 0), 0) scale(1.045);
  }
  .thumb-row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 14px;
    margin-top: 16px;
  }
  .thumb {
    height: 78px;
    border: 2px solid transparent;
    border-radius: 8px;
    overflow: hidden;
    background: #f6f7fb;
    padding: 0;
    cursor: pointer;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .thumb.is-active {
    border-color: var(--navy);
    box-shadow: 0 8px 18px rgba(7, 27, 99, 0.18);
  }
  .thumb:hover {
    transform: translateY(-2px);
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: translate3d(var(--mx, 0), var(--my, 0), 0) scale(1.01);
    transition: transform 0.45s ease;
  }
  .thumb:hover img {
    transform: translate3d(var(--mx, 0), var(--my, 0), 0) scale(1.055);
  }
  .product-panel {
    position: sticky;
    top: 96px;
    max-height: calc(100vh - 110px);
    overflow-y: auto;
    overflow-x: hidden;
    padding: 22px 22px 20px;
    border: 1px solid var(--hairline);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: 0 20px 55px rgba(7, 27, 99, 0.08);
    backdrop-filter: blur(14px);
    scrollbar-width: thin;
    scrollbar-color: var(--hairline) transparent;
  }
  .product-panel::-webkit-scrollbar { width: 6px; }
  .product-panel::-webkit-scrollbar-thumb { background: var(--hairline); border-radius: 3px; }
  .product-panel::-webkit-scrollbar-track { background: transparent; }
  .booking-head {
    padding-bottom: 12px;
    border-bottom: 1px solid var(--hairline);
    margin-bottom: 16px;
  }
  .booking-head span {
    display: block;
    color: var(--muted);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 800;
    margin-bottom: 4px;
  }
  .booking-head strong {
    display: block;
    color: var(--ink);
    font-size: 22px;
    line-height: 1.1;
  }
  .booking-sub {
    color: var(--muted);
    font-size: 12px;
    margin: 6px 0 0;
    line-height: 1.4;
  }
  .booking-field {
    margin-bottom: 10px;
  }
  .booking-field label {
    display: block;
    font-size: 12px;
    font-weight: 700;
    color: var(--ink-soft);
    margin-bottom: 4px;
  }
  .booking-input {
    width: 100%;
    height: 38px;
    padding: 0 12px;
    border: 1px solid var(--hairline);
    border-radius: 8px;
    font-size: 13px;
    color: var(--ink);
    background: #fff;
    transition: border-color 0.2s;
  }
  .booking-input:focus {
    outline: none;
    border-color: var(--navy);
  }
  .booking-section {
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px solid var(--hairline);
  }
  .booking-section h3 {
    font-size: 13px;
    font-weight: 800;
    color: var(--ink);
    margin: 0 0 8px;
  }
  .ticket-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 8px;
    padding: 6px 0;
    border-bottom: 1px solid var(--hairline);
  }
  .ticket-row:last-child {
    border-bottom: none;
  }
  .ticket-name {
    font-size: 13px;
    color: var(--ink);
  }
  .ticket-price {
    font-size: 13px;
    font-weight: 700;
    color: var(--navy);
    white-space: nowrap;
  }
  .ticket-row .quantity-stepper {
    width: 86px;
    height: 28px;
    grid-template-columns: 26px 1fr 26px;
  }
  .ticket-row .quantity-stepper button,
  .ticket-row .quantity-stepper span {
    font-size: 13px;
  }
  .addon-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 8px;
    padding: 6px 0;
    border-bottom: 1px solid var(--hairline);
    cursor: pointer;
    font-size: 12px;
    color: var(--ink);
  }
  .addon-row:last-child {
    border-bottom: none;

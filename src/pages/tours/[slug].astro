---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import FloatChat from '../../components/FloatChat.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

type TourData = CollectionEntry<'tours'>['data'] & { slug: string };

export async function getStaticPaths() {
  const entries = await getCollection('tours');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { tour: { ...entry.data, slug: entry.slug } },
  }));
}

interface Props { tour: TourData }
const { tour } = Astro.props;

const city = tour.region.split(/[·路]/)[0].trim();
const title = `${tour.title}${tour.subtitle ? ' - ' + tour.subtitle : ''} | Harmony Retreats`;
const priceStr = tour.priceFrom.toLocaleString('en-US');

const galleryPool = [
  tour.image,
  '/assets/jade-hero-wellness.png',
  '/assets/story-concierge-lounge.png',
  '/assets/huangshan-cultural-trek.png',
  '/assets/sichuan-hot-spring.png',
  '/assets/suzhou-silk-garden.png',
].filter((src, index, arr) => arr.indexOf(src) === index);


const dayTemplates: Record<TourData['category'], string[]> = {
  Wellness: [
    'Arrival and private transfer. Settle into your lakeside hotel, meet your concierge, and begin with a quiet tea ceremony.',
    'Morning TCM diagnostic with a licensed physician, personal herbal formulation, and an easy lakeside walk.',
    'Acupuncture session, guided Tai Chi at dawn, and a vegetarian cuisine workshop.',
    'Hot-spring half-day, meridian massage, and afternoon at leisure in the garden pavilion.',
    'Optional day trip to a tea-mountain retreat, with calligraphy or Guqin class on return.',
    'Final consultation, take-home prescriptions translated, and farewell dinner.',
    'Private transfer to airport. Post-trip telehealth can be booked if requested.',
  ],
  Medical: [
    'Airport meet-and-greet and check-in at a quiet recovery hotel close to the partner hospital.',
    'Pre-screening intake, bloodwork, ECG, imaging, and specialist scheduling.',
    'Specialist consultations, results review, and English-language report preparation.',
    'Post-screening rest day with gentle city excursion or in-house recovery treatment.',
  ],
  Culture: [
    'Arrival, orientation walk, and cultural curator briefing over a regional welcome dinner.',
    'Early sunrise expedition, heritage site tour, and regional cuisine dinner.',
    'Craft workshop, artisan visit, and afternoon hiking with a bilingual guide.',
    'Off-the-grid village stay and twilight meditation by ancient pine.',
    'Museum and private gallery access with curator-led conversation.',
    'Slow morning, optional photography session, and seasonal banquet.',
  ],
  Bespoke: [
    'Arrival by private vehicle, meeting with the route designer, and welcome banquet.',
    'Ancient Tea Horse Road segment, post-station stay, and regional cuisine.',
    'Forest soak and herbalist consultation among Pu-erh terraces.',
    'Optional Naxi music evening or sound-bath practice in a temple courtyard.',
    'Day trek with mule porters, highland picnic, and stargazing camp.',
    'Craft village stay with indigo dye or silver work workshop.',
    'Concluding wellness review and home-practice plan.',
  ],
};

const days = dayTemplates[tour.category].slice(0, Math.min(tour.nights, dayTemplates[tour.category].length));
const inclusions = [
  'Bilingual concierge accompaniment throughout the journey',
  'Boutique accommodation and daily breakfast',
  'Private in-trip transfers',
  'Entrance fees to scheduled partner sites',
  'Medical or wellness consultations as listed',
  '24-hour support during your stay',
];
const imageRows = galleryPool.slice(0, 4);
---

<Layout title={title} description={`${tour.title} ${tour.subtitle || ''} product detail page.`}>
  <Nav />

  <main class="product-page">
    <section class="product-shell">
      <div class="container product-layout">
        <div class="product-main">
          <div class="product-intro">
            <div class="product-kicker">{tour.category} tour</div>
            <div class="title-row">
              <h1>{tour.title}{tour.subtitle && <span>{tour.subtitle}</span>}</h1>
              <a class="expand-link" href={tour.image} target="_blank" rel="noopener" aria-label="Open main image">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M21 14v7h-7"/><path d="M3 10V3h7"/><path d="M3 21l7-7"/></svg>
              </a>
            </div>
            <p class="summary">
              Step into a curated {tour.nights}-night journey in {city}. Every day balances meaningful experiences, credentialed care, and quiet recovery, with a bilingual concierge holding the details from arrival to departure.
            </p>
            <div class="days-line">Number of travel days: <strong>{Math.max(1, Math.ceil(tour.nights / 3))}-{tour.nights} days</strong></div>
          </div>

          <div class="product-gallery">
            <div class="main-image">
              <img src={tour.image} alt={tour.alt} loading="eager" />
            </div>
            <div class="thumb-row" aria-label="Tour image thumbnails">
              {galleryPool.slice(0, 5).map((src, index) => (
                <button class={`thumb ${index === 0 ? 'is-active' : ''}`} type="button" data-gallery-src={src}>
                  <img src={src} alt="" loading="lazy" />
                </button>
              ))}
            </div>
          </div>

          <section class="product-content">
            <nav class="detail-tabs" aria-label="Tour detail sections">
              <a href="#detail" class="active">Detail</a>
              <a href="#included">What's included</a>
              <a href="#not-included">Not included</a>
              <a href="#review">Review</a>
            </nav>

            <div id="detail" class="detail-copy">
              <h2>{tour.title} itinerary</h2>
              <p>
                This itinerary is designed for international guests who want a clear product-style tour while keeping the high-touch Harmony Retreats service layer. Timings can be adjusted, but the rhythm below shows how your days may unfold.
              </p>

              {days.map((day, index) => (
                <article class="day-section">
                  <h3>Day {index + 1}: {index === 0 ? city : tour.category}</h3>
                  <p>{day}</p>
                  <div class="image-table">
                    <div class="table-label">{index === 0 ? tour.title : tour.subtitle || tour.category}</div>
                    {imageRows.map((src) => (
                      <div class="table-img">
                        <img src={src} alt="" loading="lazy" />
                      </div>
                    ))}
                  </div>
                </article>
              ))}
            </div>

            <div id="included" class="included-panel">
              <h2>What's included</h2>
              <div class="included-grid">
                {inclusions.map((item) => <div class="included-item">{item}</div>)}
              </div>
            </div>

            <div id="not-included" class="included-panel">
              <h2>Not included</h2>
              <div class="included-grid">
                <div class="included-item">International flights (we can arrange on request)</div>
                <div class="included-item">Personal travel insurance (mandatory; partner referral available)</div>
                <div class="included-item">Visa application fees (we provide invitation letters)</div>
                <div class="included-item">Gratuities and personal shopping</div>
                <div class="included-item">Optional add-on experiences priced separately</div>
              </div>
            </div>

            <div id="review" class="review-panel">
              <h2>Guest review</h2>
              <p>"Everything felt precise, but never rushed. The concierge made the medical and cultural parts feel like one continuous journey."</p>
              <strong>Rating {tour.rating.toFixed(2)} / 5.00 · {tour.reviews} reviews</strong>
            </div>
          </section>
        </div>

        <aside class="product-panel">
          <div class="booking-head">
            <span>Booking summary</span>
            <strong>From ${priceStr}</strong>
            <p class="booking-sub">Final quote confirmed by your concierge.</p>
          </div>

          <div class="booking-field">
            <label>Check-in date</label>
            <input type="date" class="booking-input" />
          </div>
          <div class="booking-field">
            <label>Check-out</label>
            <input type="date" class="booking-input" />
          </div>

          <div class="booking-section">
            <h3>Ticket type</h3>
            <div class="ticket-row">
              <span class="ticket-name">Adult package</span>
              <span class="ticket-price">${priceStr}</span>
              <div class="quantity-stepper" data-qty>
                <button type="button" data-qty-minus aria-label="Decrease quantity">-</button>
                <span data-qty-value>1</span>
                <button type="button" data-qty-plus aria-label="Increase quantity">+</button>
              </div>
            </div>
            <div class="ticket-row">
              <span class="ticket-name">Senior package</span>
              <span class="ticket-price">${(tour.priceFrom * 1.1).toLocaleString('en-US', {maximumFractionDigits: 0})}</span>
              <div class="quantity-stepper" data-qty>
                <button type="button" data-qty-minus aria-label="Decrease quantity">-</button>
                <span data-qty-value>0</span>
                <button type="button" data-qty-plus aria-label="Increase quantity">+</button>
              </div>
            </div>
            <div class="ticket-row">
              <span class="ticket-name">Family package</span>
              <span class="ticket-price">${(tour.priceFrom * 2.8).toLocaleString('en-US', {maximumFractionDigits: 0})}</span>
              <div class="quantity-stepper" data-qty>
                <button type="button" data-qty-minus aria-label="Decrease quantity">-</button>
                <span data-qty-value>0</span>
                <button type="button" data-qty-plus aria-label="Increase quantity">+</button>
              </div>
            </div>
          </div>

          <div class="booking-section">
            <h3>Add-on services</h3>
            <label class="addon-row">
              <input type="checkbox" />
              <span class="addon-name">All in-trip transfers in private vehicles</span>
              <span class="addon-price">+$320</span>
            </label>
            <label class="addon-row">
              <input type="checkbox" />
              <span class="addon-name">24-hour medical hotline during your stay</span>
              <span class="addon-price">+$80</span>
            </label>
            <label class="addon-row">
              <input type="checkbox" />
              <span class="addon-name">Daily breakfast + curated regional dining experiences</span>
              <span class="addon-price">+$150</span>
            </label>
          </div>

          <div class="booking-total">
            <span>Total estimate</span>
            <strong>${priceStr}</strong>
          </div>
          <a class="book-btn" href="/contact">Book Now</a>
          <p class="booking-note">No deposit required to enquire. Custom adjustments welcome.</p>
        </aside>
      </div>
    </section>
  </main>

  <Footer />
  <FloatChat />
</Layout>

<style>
  .product-page {
    background: #fff;
    color: var(--ink);
  }
  .product-shell {
    padding: 46px 0 96px;
    background:
      linear-gradient(180deg, #fff 0%, #fff 56%, var(--sky-mist) 100%);
  }
  .product-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(430px, 500px);
    gap: clamp(42px, 5vw, 72px);
    align-items: start;
    max-width: 1500px;
  }
  .product-main {
    min-width: 0;
  }
  .product-intro {
    margin-bottom: 28px;
    padding: 4px 0 6px;
  }
  .product-gallery {
    min-width: 0;
  }
  .main-image {
    aspect-ratio: 16 / 10.5;
    background: #f3f4f6;
    overflow: hidden;
    border-radius: 10px;
    box-shadow: 0 18px 46px rgba(7, 27, 99, 0.1);
  }
  .main-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: translate3d(var(--mx, 0), var(--my, 0), 0) scale(1.01);
    transition: transform 0.8s cubic-bezier(.2,.7,.2,1);
  }
  .main-image:hover img {
    transform: translate3d(var(--mx, 0), var(--my, 0), 0) scale(1.045);
  }
  .thumb-row {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 14px;
    margin-top: 16px;
  }
  .thumb {
    height: 78px;
    border: 2px solid transparent;
    border-radius: 8px;
    overflow: hidden;
    background: #f6f7fb;
    padding: 0;
    cursor: pointer;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .thumb.is-active {
    border-color: var(--navy);
    box-shadow: 0 8px 18px rgba(7, 27, 99, 0.18);
  }
  .thumb:hover {
    transform: translateY(-2px);
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: translate3d(var(--mx, 0), var(--my, 0), 0) scale(1.01);
    transition: transform 0.45s ease;
  }
  .thumb:hover img {
    transform: translate3d(var(--mx, 0), var(--my, 0), 0) scale(1.055);
  }
  .product-panel {
    position: sticky;
    top: 112px;
    min-height: 0;
    max-height: none;
    overflow: visible;
    padding: 32px;
    border: 1px solid var(--hairline);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.86);
    box-shadow: 0 20px 55px rgba(7, 27, 99, 0.08);
    backdrop-filter: blur(14px);
  }
  .booking-head {
    padding-bottom: 18px;
    border-bottom: 1px solid var(--hairline);
    margin-bottom: 24px;
  }
  .booking-head span {
    display: block;
    color: var(--muted);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 800;
    margin-bottom: 6px;
  }
  .booking-head strong {
    display: block;
    color: var(--ink);
    font-size: 28px;
    line-height: 1.1;
  }
  .booking-sub {
    color: var(--muted);
    font-size: 13px;
    margin: 8px 0 0;
    line-height: 1.4;
  }
  .booking-field {
    margin-bottom: 16px;
  }
  .booking-field label {
    display: block;
    font-size: 13px;
    font-weight: 700;
    color: var(--ink-soft);
    margin-bottom: 6px;
  }
  .booking-input {
    width: 100%;
    height: 46px;
    padding: 0 14px;
    border: 1px solid var(--hairline);
    border-radius: 8px;
    font-size: 14px;
    color: var(--ink);
    background: #fff;
    transition: border-color 0.2s;
  }
  .booking-input:focus {
    outline: none;
    border-color: var(--navy);
  }
  .booking-section {
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid var(--hairline);
  }
  .booking-section h3 {
    font-size: 15px;
    font-weight: 800;
    color: var(--ink);
    margin: 0 0 14px;
  }
  .ticket-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--hairline);
  }
  .ticket-row:last-child {
    border-bottom: none;
  }
  .ticket-name {
    font-size: 14px;
    color: var(--ink);
  }
  .ticket-price {
    font-size: 14px;
    font-weight: 700;
    color: var(--navy);
    white-space: nowrap;
  }
  .ticket-row .quantity-stepper {
    width: 100px;
    height: 34px;
    grid-template-columns: 30px 1fr 30px;
  }
  .ticket-row .quantity-stepper button,
  .ticket-row .quantity-stepper span {
    font-size: 14px;
  }
  .addon-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 10px;
    padding: 10px 0;
    border-bottom: 1px solid var(--hairline);
    cursor: pointer;
    font-size: 13px;
    color: var(--ink);
  }
  .addon-row:last-child {
    border-bottom: none;
  }
  .addon-row input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: var(--navy);
  }
  .addon-name {
    line-height: 1.3;
  }
  .addon-price {
    font-weight: 700;
    color: var(--orange);
    white-space: nowrap;
  }
  .booking-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid var(--hairline);
    margin-bottom: 16px;
  }
  .booking-total span {
    font-size: 15px;
    font-weight: 700;
    color: var(--ink);
  }
  .booking-total strong {
    font-size: 26px;
    color: var(--orange);
  }
  .booking-note {
    text-align: center;
    font-size: 12px;
    color: var(--muted);
    margin-top: 10px;
  }
  .product-kicker {
    color: var(--navy);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .title-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 18px;
    align-items: start;
  }
  .title-row h1 {
    font-family: 'Inter', -apple-system, sans-serif;
    font-size: clamp(34px, 4vw, 54px);
    line-height: 1.18;
    font-weight: 900;
    color: var(--ink);
    margin: 0;
  }
  .title-row h1 span {
    display: block;
    color: var(--navy-soft);
    font-size: 0.82em;
    margin-top: 6px;
  }
  .expand-link {
    width: 38px;
    height: 38px;
    border-radius: 8px;
    display: grid;
    place-items: center;
    color: var(--muted);
  }
  .expand-link:hover {
    background: var(--sky-mist);
    color: var(--navy);
  }
  .summary {
    color: var(--muted);
    font-size: 17px;
    line-height: 1.65;
    max-width: 760px;
    margin: 18px 0 24px;
  }
  .product-line {
    height: 1px;
    background: var(--hairline);
    margin: 22px 0;
  }
  .days-line {
    color: var(--orange);
    font-size: 20px;
    padding: 18px 20px;
    border: 1px solid rgba(241, 90, 36, 0.25);
    border-radius: 10px;
    background: var(--sand);
    max-width: 420px;
  }
  .days-line strong {
    font-weight: 500;
  }
  .quantity-stepper {
    display: grid;
    grid-template-columns: 70px 1fr 70px;
    width: 100%;
    height: 54px;
    border: 1px solid var(--hairline);
    border-radius: 8px;
    overflow: hidden;
  }
  .quantity-stepper button,
  .quantity-stepper span {
    display: grid;
    place-items: center;
    font-size: 18px;
    background: #fff;
  }
  .quantity-stepper button {
    color: var(--muted);
    font-weight: 900;
  }
  .quantity-stepper button:hover {
    color: var(--navy);
    background: var(--sky-mist);
  }
  .book-btn {
    width: 100%;
    min-width: 0;
    height: 56px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: var(--orange);
    color: var(--ink);
    font-weight: 800;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .book-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 28px rgba(241, 90, 36, 0.24);
  }

  .product-content {
    padding: 56px 0 0;
  }
  .detail-tabs {
    position: sticky;
    top: 88px;
    z-index: 10;
    display: flex;
    gap: 0;
    background: #fff;
    border: 1px solid var(--hairline);
    margin-bottom: 42px;
    box-shadow: 0 12px 30px rgba(7, 27, 99, 0.05);
  }
  .detail-tabs a {
    min-width: 180px;
    padding: 18px 24px;
    text-align: center;
    color: var(--ink-soft);
    text-decoration: none;
    border-right: 1px solid var(--hairline);
  }
  .detail-tabs a.active {
    background: #f2f2f2;
    color: var(--orange-deep);
  }
  .detail-copy h2,
  .included-panel h2,
  .review-panel h2 {
    color: var(--navy);
    font-size: 28px;
    margin: 0 0 22px;
  }
  .detail-copy p,
  .day-section p,
  .review-panel p {
    color: var(--ink);
    font-size: 18px;
    line-height: 1.8;
  }
  .day-section {
    margin-top: 46px;
    padding-top: 8px;
  }
  .day-section h3 {
    color: var(--navy);
    font-size: 24px;
    margin: 0 0 22px;
  }
  .image-table {
    display: grid;
    grid-template-columns: 1fr repeat(4, 1fr);
    border: 1px solid var(--hairline);
    margin-top: 28px;
    overflow: hidden;
    border-radius: 4px;
  }
  .table-label,
  .table-img {
    min-height: 180px;
    border-right: 1px solid var(--hairline);
    display: grid;
    place-items: center;
    padding: 12px;
  }
  .table-label {
    background: #f5f5f5;
    color: var(--orange-deep);
    font-size: 17px;
    text-align: center;
  }
  .table-img:last-child {
    border-right: none;
  }
  .table-img img {
    width: 100%;
    height: 150px;
    object-fit: cover;
    transform: translate3d(var(--mx, 0), var(--my, 0), 0) scale(1.01);
    transition: transform 0.5s ease, filter 0.3s ease;
  }
  .table-img:hover img {
    transform: translate3d(var(--mx, 0), var(--my, 0), 0) scale(1.055);
    filter: saturate(1.04);
  }
  .included-panel,
  .review-panel {
    margin-top: 64px;
    padding-top: 42px;
    border-top: 1px solid var(--hairline);
  }
  .included-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .included-item {
    padding: 18px 20px;
    border: 1px solid var(--hairline);
    border-radius: 8px;
    color: var(--ink);
    background: #fff;
  }
  .review-panel strong {
    display: inline-block;
    color: var(--orange);
    margin-top: 12px;
  }

  @media (max-width: 1000px) {
    .product-layout {
      grid-template-columns: 1fr;
    }
    .product-panel {
      position: static;
      min-height: auto;
      max-height: none;
      overflow: visible;
    }
    .image-table {
      grid-template-columns: 1fr 1fr;
    }
    .table-label {
      grid-column: 1 / -1;
    }
    .included-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .product-shell {
      padding-top: 32px;
    }
    .thumb-row {
      grid-template-columns: repeat(3, 1fr);
    }
    .product-panel {
      padding: 22px 18px;
      border-radius: 10px;
    }
    .title-row h1 {
      font-size: 28px;
    }
    .book-btn {
      width: 100%;
    }
    .detail-tabs {
      overflow-x: auto;
    }
    .detail-tabs a {
      min-width: 150px;
    }
    .image-table {
      grid-template-columns: 1fr;
    }
    .table-label,
    .table-img {
      min-height: auto;
      border-right: none;
      border-bottom: 1px solid var(--hairline);
    }
    .table-img img {
      height: 210px;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-gallery-src]').forEach((button) => {
    button.addEventListener('click', () => {
      const image = document.querySelector<HTMLImageElement>('.main-image img');
      const src = button.dataset.gallerySrc;
      if (!image || !src) return;
      image.src = src;
      document.querySelectorAll('[data-gallery-src]').forEach((item) => item.classList.remove('is-active'));
      button.classList.add('is-active');
    });
  });

  document.querySelectorAll<HTMLElement>('[data-qty]').forEach((root) => {
    const display = root.querySelector<HTMLElement>('[data-qty-value]');
    if (!display) return;
    let qty = parseInt(display.textContent || '0', 10);
    root.querySelector('[data-qty-minus]')?.addEventListener('click', () => {
      qty = Math.max(0, qty - 1);
      display.textContent = String(qty);
    });
    root.querySelector('[data-qty-plus]')?.addEventListener('click', () => {
      qty += 1;
      display.textContent = String(qty);
    });
  });
</script>

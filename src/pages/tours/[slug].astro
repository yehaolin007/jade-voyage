<script>
  document.querySelectorAll<HTMLButtonElement>('[data-gallery-src]').forEach((button) => {
    button.addEventListener('click', () => {
      const image = document.querySelector<HTMLImageElement>('.main-image img');
      const src = button.dataset.gallerySrc;
      if (!image || !src) return;
      image.src = src;
      document.querySelectorAll('[data-gallery-src]').forEach((item) => item.classList.remove('is-active'));
      button.classList.add('is-active');
    });
  });

  const totalDisplay = document.querySelector<HTMLElement>('[data-total-display]');
  const payLink = document.querySelector<HTMLAnchorElement>('[data-pay-link]');
  const ticketRows = document.querySelectorAll<HTMLElement>('[data-ticket-row]');
  const addonRows = document.querySelectorAll<HTMLElement>('[data-addon-row]');

  function recomputeTotal() {
    let total = 0;
    ticketRows.forEach((row) => {
      const unit = parseFloat(row.dataset.unitPrice || '0');
      const qtyValue = row.querySelector<HTMLElement>('[data-qty-value]');
      const qty = parseInt(qtyValue?.textContent || '0', 10);
      total += unit * qty;
    });
    addonRows.forEach((row) => {
      const checkbox = row.querySelector<HTMLInputElement>('input[type="checkbox"]');
      if (checkbox?.checked) {
        total += parseFloat(row.dataset.addonPrice || '0');
      }
    });
    if (totalDisplay) {
      totalDisplay.textContent = '$' + total.toLocaleString('en-US');
    }
    if (payLink) {
      const base = payLink.dataset.payBase || '';
      const currency = payLink.dataset.payCurrency || 'USD';
      payLink.href = `${base}${total}${currency}`;
    }
  }

  document.querySelectorAll<HTMLElement>('[data-qty]').forEach((root) => {
    const display = root.querySelector<HTMLElement>('[data-qty-value]');
    if (!display) return;
    let qty = parseInt(display.textContent || '0', 10);
    root.querySelector('[data-qty-minus]')?.addEventListener('click', () => {
      qty = Math.max(0, qty - 1);
      display.textContent = String(qty);
      recomputeTotal();
    });
    root.querySelector('[data-qty-plus]')?.addEventListener('click', () => {
      qty += 1;
      display.textContent = String(qty);
      recomputeTotal();
    });
  });

  addonRows.forEach((row) => {
    const checkbox = row.querySelector<HTMLInputElement>('input[type="checkbox"]');
    checkbox?.addEventListener('change', recomputeTotal);
  });
</script>

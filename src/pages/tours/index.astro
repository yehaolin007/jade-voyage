---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import FloatChat from '../../components/FloatChat.astro';
import PageHero from '../../components/PageHero.astro';
import TourCard from '../../components/TourCard.astro';
import { getCollection } from 'astro:content';

const tours = (await getCollection('tours', ({ data }) => data.featured)).sort((a, b) => a.data.order - b.data.order);
const categories = ['All', ...Array.from(new Set(tours.map((tour) => tour.data.category)))];
---

<Layout title="All Packages — Harmony Retreats" description="Browse Chongqing checkup, TCM heritage and travel packages with clear concierge support.">
  <Nav />

  <PageHero
    eyebrow="All Packages"
    title="Chongqing wellness packages with clear scope."
    subtitle="Filter by package category, or speak with us about a fully custom Chongqing plan."
    bgImage="/assets/products/chongqing-skyline.png"
    crumbs={[{ label: 'Home', href: '/' }, { label: 'Packages' }]}
  />

  <section class="tours-listing">
    <div class="container">
      <div class="filter-bar">
        <div class="filter-group">
          <span class="filter-label">Category</span>
          <div class="chips">
            {categories.map((c, i) => (
              <button class:list={['chip', i === 0 && 'active']} data-cat={c}>{c}</button>
            ))}
          </div>
        </div>
        <div class="result-count">
          <span class="count-num">{tours.length}</span> packages · updated from latest product brief
        </div>
      </div>

      <div class="tours-grid tours-grid-page">
        {tours.map((t) => <TourCard entry={t} />)}
      </div>

      <div class="bespoke-cta">
        <div>
          <span class="micro">— Need a different pace?</span>
          <h3>We build custom Chongqing plans for each guest.</h3>
          <p>Tell us your dates, checkup needs, TCM interests and travel rhythm — we'll send a private proposal within 48 hours.</p>
        </div>
        <a href="/contact" class="btn btn-primary">Request a Custom Proposal →</a>
      </div>
    </div>
  </section>

  <Footer />
  <FloatChat />
</Layout>

<style>
  .tours-listing { padding: 80px 0 96px; background: var(--canvas); }
  .filter-bar {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 32px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--hairline);
    margin-bottom: 48px;
    flex-wrap: wrap;
  }
  .filter-label {
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-right: 16px;
  }
  .filter-group { display: flex; align-items: center; flex-wrap: wrap; gap: 12px; }
  .chips { display: flex; gap: 8px; flex-wrap: wrap; }
  .chip {
    padding: 8px 18px;
    border-radius: 9999px;
    border: 1px solid var(--hairline);
    background: var(--canvas);
    color: var(--ink-soft);
    font-size: 13px;
    font-weight: 500;
    transition: all 0.2s;
  }
  .chip:hover { border-color: var(--jade); color: var(--jade-deep); }
  .chip.active { background: var(--ink); border-color: var(--ink); color: var(--canvas); }
  .result-count { color: var(--muted); font-size: 14px; }
  .count-num { color: var(--ink); font-weight: 600; font-family: 'Cormorant Garamond', serif; font-size: 22px; }
  .tours-grid-page { margin-bottom: 80px; }
  .bespoke-cta {
    background:
      linear-gradient(135deg, rgba(255, 246, 241, 0.96), rgba(255, 255, 255, 0.96)),
      repeating-linear-gradient(60deg, rgba(7, 27, 99, 0.035) 0 1px, transparent 1px 28px);
    border: 1px solid var(--hairline);
    border-radius: 12px;
    padding: 40px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }
  .bespoke-cta h3 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-size: 30px;
    color: var(--ink);
    margin: 12px 0 8px;
    max-width: 560px;
  }
  .bespoke-cta p { color: var(--ink-soft); max-width: 560px; }
  .bespoke-cta .micro { color: var(--jade-deep); }

  @media (max-width: 760px) {
    .tours-listing { padding: 56px 0 72px; }
    .filter-bar {
      align-items: flex-start;
      gap: 20px;
      margin-bottom: 34px;
    }
    .filter-group {
      align-items: flex-start;
      flex-direction: column;
    }
    .chip { padding: 10px 16px; }
    .bespoke-cta {
      padding: 30px 24px;
    }
    .bespoke-cta .btn {
      justify-content: center;
      width: 100%;
    }
  }
</style>

<script>
  const chips = document.querySelectorAll<HTMLButtonElement>('.chip');
  const cards = document.querySelectorAll<HTMLElement>('.tours-grid-page > .tour-card');
  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      chips.forEach((c) => c.classList.remove('active'));
      chip.classList.add('active');
      const cat = chip.dataset.cat;
      cards.forEach((card) => {
        const match = cat === 'All' || card.dataset.category === cat;
        card.style.display = match ? '' : 'none';
      });
    });
  });
</script>

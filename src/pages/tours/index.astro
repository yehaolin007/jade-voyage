---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import FloatChat from '../../components/FloatChat.astro';
import PageHero from '../../components/PageHero.astro';
import TourCard from '../../components/TourCard.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getCollection } from 'astro:content';
import { wellnessTravelPackages, checkupTravelPackages } from '../../data/packages';

const featuredTours = (await getCollection('tours', ({ data }) => data.featured)).sort((a, b) => a.data.order - b.data.order);
---

<Layout title="All Packages — Harmony Retreats" description="Browse our featured Chongqing journeys, wellness-and-travel and health-check-and-travel packages with clear concierge support.">
  <Nav />

  <PageHero
    eyebrow="All Packages"
    title="Chongqing journeys with clear scope."
    subtitle="Three ways to travel with us — featured journeys, wellness-and-travel and health-check-and-travel packages, all supported by one bilingual concierge."
    bgImage="/assets/products/chongqing-skyline.png"
    crumbs={[{ label: 'Home', href: '/' }, { label: 'Packages' }]}
  />

  <section class="tours-listing">
    <div class="container">
      <div class="pkg-group-head">
        <span class="micro">Featured</span>
        <h2>Featured Packages <span class="zh">主推产品</span></h2>
        <p class="group-deck">Our most-booked Chongqing journeys, each with a full detail page and booking options.</p>
      </div>
      <div class="tours-grid pkg-grid">
        {featuredTours.map((t) => <TourCard entry={t} />)}
      </div>

      <div class="pkg-group-head">
        <span class="micro">Wellness + Travel</span>
        <h2>Wellness Journeys <span class="zh">理疗 + 旅游</span></h2>
        <p class="group-deck">Advanced TCM therapies paired with mountain-and-water travel across Chongqing, Sichuan and the Three Gorges.</p>
      </div>
      <div class="tours-grid pkg-grid">
        {wellnessTravelPackages.map((p) => <ProductCard product={p} />)}
      </div>

      <div class="pkg-group-head">
        <span class="micro">Health Check + Travel</span>
        <h2>Health Check Journeys <span class="zh">体检 + 旅游</span></h2>
        <p class="group-deck">Xueping health-check packages combined with leisurely city sightseeing and scenic touring.</p>
      </div>
      <div class="tours-grid pkg-grid">
        {checkupTravelPackages.map((p) => <ProductCard product={p} />)}
      </div>

      <div class="bespoke-cta">
        <div>
          <span class="micro">— Need a different pace?</span>
          <h3>We build custom Chongqing plans for each guest.</h3>
          <p>Tell us your dates, checkup needs, TCM interests and travel rhythm — we'll send a private proposal within 48 hours.</p>
        </div>
        <a href="/contact" class="btn btn-primary">Request a Custom Proposal →</a>
      </div>
    </div>
  </section>

  <Footer />
  <FloatChat />
</Layout>

<style>
  .tours-listing { padding: 80px 0 96px; background: var(--canvas); }

  .pkg-group-head { max-width: 720px; margin-bottom: 36px; }
  .pkg-group-head .micro { color: var(--orange-deep); margin-bottom: 14px; display: inline-block; }
  .pkg-group-head h2 {
    font-family: 'Inter', -apple-system, sans-serif;
    font-weight: 800;
    font-size: clamp(28px, 3.4vw, 40px);
    line-height: 1.12;
    color: var(--navy);
    letter-spacing: -0.01em;
  }
  .pkg-group-head h2 .zh {
    font-family: 'Noto Serif SC', serif;
    font-weight: 500;
    font-size: 0.56em;
    color: var(--muted);
    letter-spacing: 0.04em;
    margin-left: 10px;
    white-space: nowrap;
  }
  .pkg-group-head .group-deck {
    color: var(--navy-soft);
    font-size: 17px;
    font-weight: 300;
    margin-top: 14px;
  }
  .tours-grid + .pkg-group-head { margin-top: 80px; }
  .tours-grid + .bespoke-cta { margin-top: 72px; }

  .bespoke-cta {
    background:
      linear-gradient(135deg, rgba(255, 246, 241, 0.96), rgba(255, 255, 255, 0.96)),
      repeating-linear-gradient(60deg, rgba(7, 27, 99, 0.035) 0 1px, transparent 1px 28px);
    border: 1px solid var(--hairline);
    border-radius: 12px;
    padding: 40px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }
  .bespoke-cta h3 {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 500;
    font-size: 30px;
    color: var(--navy);
    margin: 12px 0 8px;
    max-width: 560px;
  }
  .bespoke-cta p { color: var(--navy-soft); max-width: 560px; }
  .bespoke-cta .micro { color: var(--orange-deep); }

  @media (max-width: 760px) {
    .tours-listing { padding: 56px 0 72px; }
    .tours-grid + .pkg-group-head { margin-top: 56px; }
    .pkg-group-head { margin-bottom: 28px; }
    .bespoke-cta {
      padding: 30px 24px;
    }
    .bespoke-cta .btn {
      justify-content: center;
      width: 100%;
    }
  }
</style>

---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import FloatChat from '../components/FloatChat.astro';
import PageHero from '../components/PageHero.astro';

const medical = [
  { name: 'The Second Affiliated Hospital of Chongqing Medical University', loc: 'Chongqing', tier: 'Class III Grade-A tertiary hospital', note: 'Tertiary hospital resource for specialist routing, inpatient coordination and medical report review.' },
  { name: 'Xueping Health · Ciming Aoya Health Management and Examination Center', loc: 'Chongqing', tier: 'Health check-up institution', note: 'Precision screening partner with quality-controlled checkup flow, imaging coordination and report handoff.' },
  { name: 'Mountain City Medical International Desk', loc: 'Chongqing', tier: 'Hospital international department', note: 'Bilingual intake, report coordination and follow-up review.' },
  { name: 'Southwest Preventive Care Partner', loc: 'Chongqing', tier: 'Screened medical partner', note: 'Cardiac, metabolic and oncology screening coordination.' },
];

const wellness = [
  { name: 'Chongqing Mingyitang Hospital', loc: 'Chongqing', tier: 'Licensed TCM clinic partner', note: 'TCM consultation, meridian care, rehabilitation support and herbal guidance for practical recovery plans.' },
  { name: 'Mountain Hot-Spring Wellness Partner', loc: 'Chongqing', tier: 'Screened wellness venue', note: 'Hot-spring recovery, guided relaxation and private transfer.' },
  { name: 'Heritage Therapy Studio', loc: 'Chongqing', tier: 'Practitioner verified', note: 'Traditional wellness routines, guest education and follow-up plan.' },
  { name: 'Post-trip Online Wellness Desk', loc: 'Remote', tier: 'Concierge follow-up', note: 'Report reading, health archive and continued consultation.' },
];

const medicalMedia = [
  { src: '/assets/credentials/cqmu-second-hospital-profile.jpg', alt: 'The Second Affiliated Hospital of Chongqing Medical University profile', eyebrow: 'CQMU Second Affiliated Hospital', title: 'Class III Grade-A hospital profile', desc: 'Hospital overview, honors and address information are presented as part of the visible credential file.' },
  { src: '/assets/credentials/cqmu-second-hospital-credentials.jpg', alt: 'Hospital honors and department credentials', eyebrow: 'Credential archive', title: 'Hospital honors and departments', desc: 'Public-facing hospital introduction, honors received and department capabilities in one reviewable set.' },
  { src: '/assets/credentials/ciming-aoya-overview.jpg', alt: 'Xueping Health Ciming Aoya overview', eyebrow: 'Health check-up center', title: 'Xueping Health · Ciming Aoya', desc: 'A focused check-up partner for precision screening, inspection flow and post-exam report coordination.' },
  { src: '/assets/credentials/ciming-aoya-certificates.jpg', alt: 'Ciming Aoya quality control certificates', eyebrow: 'Check-up quality file', title: 'Quality control certificates', desc: 'Selected certificates and quality-control materials support the medical screening workflow.' },
];

const wellnessMedia = [
  { src: '/assets/credentials/mingyitang-care-cover.jpg', alt: 'Mingyitang TCM heritage clinic cover', eyebrow: 'Licensed TCM partner', title: 'Mingyitang TCM Heritage Clinic', desc: 'Branded TCM clinic materials show the partner positioning and recovery service scope.' },
  { src: '/assets/credentials/mingyitang-branches.jpg', alt: 'Mingyitang Chongqing clinic storefront network', eyebrow: 'Clinic storefronts', title: 'Chongqing clinic network', desc: 'Branch and storefront materials help guests understand where care is delivered before booking.' },
  { src: '/assets/credentials/mingyitang-expert-team.jpg', alt: 'Mingyitang practitioner team archive', eyebrow: 'Expert archive', title: 'Practitioner team', desc: 'Doctor and practitioner profiles are reviewed before a guest itinerary is confirmed.' },
  { src: '/assets/credentials/mingyitang-treatment-scenes.jpg', alt: 'Mingyitang treatment and consultation scenes', eyebrow: 'Service evidence', title: 'Therapy scenes', desc: 'Treatment and consultation scenes are used to explain what the in-person experience looks like.' },
];

const travelMedia = [
  { src: '/bb5cdf49de2554685d1675558d7aba31.jpg', alt: 'Travel Agency Operating License', eyebrow: 'Licensed travel operator', title: 'Travel Agency Operating License', desc: 'Issued by the Ministry of Culture and Tourism, covering domestic and inbound tourism operations.' },
  { src: '/6e293c8bb2abb7b165e983f7c2fc4463.jpg', alt: 'Business registration license', eyebrow: 'Business registration', title: 'Business License', desc: 'Registered travel company with verified capital and legally approved scope of tourism services.' },
];

const mediaBySection = {
  medical: medicalMedia,
  wellness: wellnessMedia,
  travel: travelMedia,
};

const sectionMedia = (id: string) => mediaBySection[id as keyof typeof mediaBySection] ?? [];

const travel = [
  { name: 'Chongqing Licensed Travel Operator', loc: 'Chongqing', tier: 'Screened agency', note: 'Airport pickup, city routing and bilingual coordination' },
  { name: 'Yangtze Riverside Route Partner', loc: 'Chongqing', tier: 'Local operator', note: 'Riverside walks, culture stops and flexible pacing' },
  { name: 'Mountain-City Food & Culture Desk', loc: 'Chongqing', tier: 'Curated experience partner', note: 'Local dining, heritage blocks and accessible routing' },
  { name: 'Custom Transfer Partner', loc: 'Chongqing', tier: 'Vehicle partner', note: 'Private cars, family routing and senior-friendly travel' },
];

const sections = [
  { id: 'medical', title: 'Hospital Credentials', cn: '医 院 资 质', heading: 'Efficient checkups with clear report support.', items: medical },
  { id: 'wellness', title: 'TCM Clinic Credentials', cn: '中 医 馆 资 质', heading: 'Licensed heritage therapies, explained plainly.', items: wellness },
  { id: 'travel', title: 'Travel Agency Credentials', cn: '旅 行 社 资 质', heading: 'Operators that make Chongqing easy to move through.', items: travel },
];
---

<Layout title="Verified Partners — Harmony Retreats" description="Hospital, TCM clinic, travel agency and privacy standards for Harmony Retreats packages.">
  <Nav />

  <PageHero
    eyebrow="Verified Partners"
    title="Every package is backed by visible partner standards."
    subtitle="We work with screened hospitals, TCM wellness partners and licensed travel operators, with standards shown clearly before booking."
    crumbs={[{ label: 'Home', href: '/' }, { label: 'Verified Partners' }]}
  />

  <section class="vp-intro">
    <div class="container vp-intro-grid">
      <div class="vp-stat">
        <div class="num">3</div>
        <div class="label">Service Categories</div>
      </div>
      <div class="vp-stat">
        <div class="num">4</div>
        <div class="label">Credential Entrances</div>
      </div>
      <div class="vp-stat">
        <div class="num">24h</div>
        <div class="label">In-trip Support</div>
      </div>
      <div class="vp-stat">
        <div class="num">100%</div>
        <div class="label">Consent-first Data Flow</div>
      </div>
    </div>
  </section>

  {sections.map((s) => (
    <section id={s.id} class="vp-section">
      <div class="container">
        <div class="vp-head">
          <span class="micro">{s.title}</span>
          <h2>{s.heading}</h2>
          <div class="cn-sub">{s.cn}</div>
          <div class="underline"></div>
        </div>
        {sectionMedia(s.id).length > 0 && (
          <div class={`credential-gallery ${sectionMedia(s.id).length <= 2 ? 'credential-gallery--compact' : ''}`} aria-label={`${s.title} visual credential file`}>
            {sectionMedia(s.id).map((media, index) => (
              <article class={`credential-card ${index === 0 && sectionMedia(s.id).length > 2 ? 'credential-card-featured' : ''}`}>
                <div class="credential-image">
                  <img src={media.src} alt={media.alt} loading="lazy" />
                </div>
                <div class="credential-copy">
                  <span>{media.eyebrow}</span>
                  <h3>{media.title}</h3>
                  <p>{media.desc}</p>
                </div>
              </article>
            ))}
          </div>
        )}
        <div class="vp-list">
          {s.items.map((it) => (
            <div class="vp-row">
              <div class="vp-mark" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M12 2L4 5v7c0 5 3.5 9 8 10 4.5-1 8-5 8-10V5l-8-3z" />
                  <path d="M9 12l2 2 4-4" />
                </svg>
              </div>
              <div class="vp-content">
                <div class="vp-name">{it.name}</div>
                <div class="vp-meta">{it.loc} · <span class="vp-tier">{it.tier}</span></div>
                <div class="vp-note">{it.note}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section id="privacy-policy" class="vp-section privacy-section">
    <div class="container">
      <div class="vp-head">
        <span class="micro">Privacy Policy</span>
        <h2>Clear consent before any medical or travel data is shared.</h2>
        <div class="cn-sub">隐 私 政 策</div>
        <div class="underline"></div>
      </div>
      <div class="privacy-grid">
        <div class="privacy-card">
          <h3>Data minimization</h3>
          <p>We collect only the information required to coordinate consultation, travel planning and partner appointments.</p>
        </div>
        <div class="privacy-card">
          <h3>Written consent</h3>
          <p>Medical information is shared with hospitals or clinics only after the guest confirms the service scope.</p>
        </div>
        <div class="privacy-card">
          <h3>Controlled access</h3>
          <p>Your file is handled by the assigned concierge team and relevant verified partners, not open call-centre staff.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="vp-foot-cta">
    <div class="container">
      <p>Looking for a specific document or partner standard? <a href="/contact">Speak with a concierge →</a></p>
      <p class="privacy">Detailed data-handling practices are available in the <a href="#privacy-policy">Privacy Policy</a> section above.</p>
    </div>
  </section>

  <Footer />
  <FloatChat />
</Layout>

<style>
  .vp-intro { padding: 64px 0; background: var(--mist); border-bottom: 1px solid var(--hairline); }
  .vp-intro-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; text-align: center; }
  .vp-stat .num {
    font-family: 'Inter', -apple-system, sans-serif;
    font-weight: 900;
    font-size: 52px;
    color: var(--ink);
    line-height: 1;
  }
  .vp-stat .label { margin-top: 10px; font-size: 13px; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; font-weight: 800; }

  .vp-section { padding: 96px 0; border-bottom: 1px solid var(--hairline); }
  .vp-section:nth-of-type(even) { background: var(--rice); }
  .vp-head { margin-bottom: 48px; max-width: 720px; }
  .vp-head .micro { color: var(--seal); margin-bottom: 14px; display: inline-block; }
  .vp-head h2 {
    font-family: 'Inter', -apple-system, sans-serif;
    font-weight: 900;
    font-size: clamp(32px, 3.7vw, 46px);
    color: var(--ink);
    line-height: 1.14;
  }
  .vp-head .cn-sub {
    font-size: 14px;
    color: var(--muted);
    letter-spacing: 0.2em;
    margin-top: 10px;
  }
  .vp-head .underline { width: 40px; height: 2px; background: var(--seal); margin-top: 20px; }

  .credential-gallery {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr) minmax(0, 0.85fr);
    gap: 18px;
    margin: -16px 0 32px;
  }
  .credential-card {
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--hairline);
    border-radius: 8px;
    background: var(--canvas);
    box-shadow: 0 12px 30px rgba(7, 27, 99, 0.06);
  }
  .credential-card-featured { grid-row: span 2; }
  .credential-gallery--compact { grid-template-columns: 1fr 1fr; }
  .credential-gallery--compact .credential-image { aspect-ratio: 4 / 3; }
  .credential-image {
    aspect-ratio: 16 / 10;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, #fff 0%, #fff8f4 100%);
    border-bottom: 1px solid var(--hairline);
  }
  .credential-card-featured .credential-image { aspect-ratio: 4 / 3; }
  .credential-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 12px;
  }
  .credential-copy {
    padding: 18px 20px 20px;
  }
  .credential-copy span {
    display: inline-block;
    margin-bottom: 8px;
    color: var(--seal);
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }
  .credential-copy h3 {
    color: var(--ink);
    font-size: 17px;
    font-weight: 900;
    line-height: 1.25;
    margin-bottom: 8px;
  }
  .credential-copy p {
    color: var(--ink-soft);
    font-size: 13px;
    line-height: 1.55;
  }

  .vp-list { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .vp-row {
    display: flex;
    gap: 18px;
    padding: 24px 28px;
    background: var(--canvas);
    border: 1px solid var(--hairline);
    border-radius: 10px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .vp-row:hover { border-color: rgba(241, 90, 36, 0.35); box-shadow: var(--shadow); }
  .vp-mark {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border: 1px solid var(--seal);
    border-radius: 50%;
    color: var(--seal);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .vp-content { flex: 1; }
  .vp-name {
    font-family: 'Inter', -apple-system, sans-serif;
    font-weight: 900;
    font-size: 18px;
    color: var(--ink);
    margin-bottom: 4px;
  }
  .vp-meta { font-size: 12px; color: var(--muted); letter-spacing: 0.06em; margin-bottom: 8px; }
  .vp-tier { color: var(--seal); font-weight: 800; }
  .vp-note { font-size: 14px; color: var(--ink-soft); line-height: 1.5; }

  .privacy-section { background: var(--canvas); }
  .privacy-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .privacy-card {
    padding: 26px 28px;
    border: 1px solid var(--hairline);
    border-radius: 10px;
    background: var(--rice);
  }
  .privacy-card h3 {
    font-size: 18px;
    font-weight: 900;
    color: var(--ink);
    margin-bottom: 10px;
  }
  .privacy-card p {
    color: var(--ink-soft);
    font-size: 14px;
    line-height: 1.6;
  }

  .vp-foot-cta { padding: 64px 0; background: var(--orange); color: var(--canvas); text-align: center; }
  .vp-foot-cta p { font-size: 17px; margin-bottom: 10px; }
  .vp-foot-cta a { color: #E8C77A; border-bottom: 1px solid #E8C77A; padding-bottom: 1px; }
  .vp-foot-cta .privacy { font-size: 13px; opacity: 0.65; }

  @media (max-width: 768px) {
    .vp-intro-grid { grid-template-columns: repeat(2, 1fr); }
    .credential-gallery { grid-template-columns: 1fr; margin-top: -8px; }
    .credential-card-featured { grid-row: auto; }
    .vp-list,
    .privacy-grid { grid-template-columns: 1fr; }
  }
</style>
